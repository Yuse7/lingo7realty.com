---
// Страница выбора тарифа /plans/. Оплата пока НЕ подключена: пользователь
// выбирает продукт (окно обучения) и жмёт «Proceed to payment», после чего
// показываем блок «оплатить пока нельзя» (без сбора email).
// Аналитика: ViewContent на загрузке, InitiateCheckout по клику «Proceed to
// payment». Когда подключите оплату - заведите «Proceed to payment» на реальную
// платёжную страницу и уберите блок «Payment unavailable».
import Head from '../components/Head.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <Head
    title="Choose your plan - Lingo7 Realty"
    description="Pick your Florida real estate exam-prep plan and study window."
    canonicalUrl="https://lingo7realty.com/plans/"
    noindex={true}
  />
</head>
<body class="sp">
  <main class="sp__wrap">
    <div class="sp__panel">
      <a class="sp__back" href="/">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        <span class="sp__merchant">Lingo7 <b>Realty</b></span>
      </a>

      <!-- Акция «только сегодня за $10»: видна лишь по чётным числам (см. promo.ts).
           Раскрывается скриптом ниже; тогда же выбирается промо-тариф. -->
      <div class="sp__promo" data-promo-banner hidden>
        <span class="sp__promoFlame" aria-hidden="true">🔥</span>
        <span>Today only - get 3 months of full access for <b>$10</b> instead of $89. Offer ends in <b data-promo-timer>00:00:00</b>.</span>
      </div>

      <div class="sp__eyebrow">
        <span class="sp__prodLabel">Florida Real Estate exam prep</span>
        <span class="sp__fresh">Updated for 2026</span>
      </div>
      <h1 class="sp__headline">Pass the Florida exam in a language you understand</h1>
      <p class="sp__subline">The full Florida question bank and timed practice tests, with every question and term explained in your own language.</p>

      <ul class="sp__benefits">
        <li><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>Every practice question explained in your language</li>
        <li><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>Tap any term to save it, with audio pronunciation</li>
        <li><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>Spaced-repetition drills so terms stick for exam day</li>
        <li><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>Full Florida question bank and timed tests, matched to the real 100-question exam</li>
      </ul>
      <p class="sp__trust">Continually updated to Florida's current exam outline (Pearson VUE / FREC) - all 19 official content areas, built on current Florida license law and FREC rules.</p>

      <div class="sp__choose">
        <div class="sp__plans">
          <button type="button" class="sp__planRow sp__planRow--promo" data-plan="3 Months" data-price="10" data-promo-row hidden>
            <span class="sp__planRadio"></span>
            <span class="sp__planMain">
              <span class="sp__planName">3 Months <em>Today only · $10</em></span>
              <span class="sp__planMeta">Full access for 3 months - today's $10 deal</span>
            </span>
            <span class="sp__planPrice"><span class="sp__planWas">$89.00</span>$10.00</span>
          </button>
          <button type="button" class="sp__planRow" data-plan="1 Week" data-price="49">
            <span class="sp__planRadio"></span>
            <span class="sp__planMain">
              <span class="sp__planName">1 Week</span>
              <span class="sp__planMeta">Full access · $49/week</span>
            </span>
            <span class="sp__planPrice">$49.00</span>
          </button>
          <button type="button" class="sp__planRow is-active" data-plan="1 Month" data-price="69">
            <span class="sp__planRadio"></span>
            <span class="sp__planMain">
              <span class="sp__planName">1 Month <em>Popular</em></span>
              <span class="sp__planMeta">Full access · about $16/week</span>
            </span>
            <span class="sp__planPrice">$69.00</span>
          </button>
          <button type="button" class="sp__planRow" data-plan="3 Months" data-price="89">
            <span class="sp__planRadio"></span>
            <span class="sp__planMain">
              <span class="sp__planName">3 Months <em>Best value</em></span>
              <span class="sp__planMeta">Full access · about $7/week</span>
            </span>
            <span class="sp__planPrice">$89.00</span>
          </button>
        </div>
        <p class="sp__note">You keep full access for the whole window - study at your own pace.</p>
      </div>

      <div class="sp__lines">
        <div class="sp__line"><span data-linename>Sales Associate · 1 Month</span><span data-lineprice>$69.00</span></div>
        <div class="sp__line sp__line--muted"><span>Billed once · no auto-renewal</span></div>
        <div class="sp__line sp__line--total"><span>Total due today</span><span data-total>$69.00</span></div>
      </div>

      <ul class="sp__perks">
        <li><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>One-time payment</li>
        <li><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>No auto-renewal</li>
        <li><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>Money back within 14 days, for any reason</li>
      </ul>

      <button class="sp__continue" type="button" data-continue>
        Proceed to payment
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </button>

      <!-- Оплата ещё не подключена: по «Proceed to payment» показываем, что оплатить пока нельзя. -->
      <div class="sp__notify" data-notify hidden>
        <div class="sp__notifyHead">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
          <span>Payment unavailable</span>
        </div>
        <p class="sp__notifyText">Online payment isn't available just yet - we're putting the final touches on checkout. Please check back soon.</p>
      </div>

      <div class="sp__powered">
        <a href="/terms/">Terms</a>
        <span class="sp__sep">·</span>
        <a href="/privacy/">Privacy</a>
      </div>
    </div>
  </main>

  <style is:global>
    *, *::before, *::after { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    [hidden] { display: none !important; }
    body.sp { font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', sans-serif; color: #1a1f36; background: #fff; -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility; overflow-x: hidden; }
    body.sp a { text-decoration: none; }

    .sp__wrap { min-height: 100vh; display: flex; justify-content: center; align-items: flex-start; padding: 64px 24px 56px; }
    .sp__panel { width: 100%; max-width: 440px; }

    .sp__back { display: inline-flex; align-items: center; gap: 8px; color: #1a1f36; margin-bottom: 40px; }
    .sp__back svg { color: #6b7280; transition: color .15s, transform .15s; }
    .sp__back:hover svg { color: #1a1f36; transform: translateX(-2px); }
    .sp__merchant { font-size: 17px; font-weight: 700; letter-spacing: -.01em; }
    .sp__merchant b { color: #34D399; font-weight: 700; }

    .sp__eyebrow { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin-bottom: 12px; }
    .sp__prodLabel { font-size: 13px; font-weight: 600; letter-spacing: .04em; text-transform: uppercase; color: #059669; }
    .sp__fresh { font-size: 11px; font-weight: 700; letter-spacing: .03em; text-transform: uppercase; color: #047857; background: rgba(52,211,153,.15); padding: 3px 9px; border-radius: 20px; }
    .sp__headline { font-size: 27px; font-weight: 700; letter-spacing: -.02em; line-height: 1.18; color: #1a1f36; margin: 0; }
    .sp__subline { font-size: 14.5px; font-weight: 500; line-height: 1.5; color: #6b7280; margin: 12px 0 0; }
    .sp__benefits { list-style: none; margin: 20px 0 0; padding: 0; display: flex; flex-direction: column; gap: 11px; }
    .sp__benefits li { display: flex; align-items: flex-start; gap: 10px; font-size: 14px; font-weight: 500; line-height: 1.4; color: #1a1f36; }
    .sp__benefits svg { color: #059669; flex: 0 0 auto; margin-top: 1px; }
    .sp__trust { margin: 16px 0 0; font-size: 12px; font-weight: 500; line-height: 1.45; color: #8792a2; }

    .sp__choose { margin: 30px 0 26px; }
    .sp__plans { display: flex; flex-direction: column; gap: 8px; }
    .sp__planRow { display: flex; align-items: center; gap: 12px; width: 100%; text-align: left; font-family: inherit; background: #fff; border: 1px solid #e6e9ee; border-radius: 10px; padding: 13px 14px; cursor: pointer; transition: border-color .15s, box-shadow .15s, background .15s; }
    .sp__planRow:hover { border-color: #c9d2dd; }
    .sp__planRow.is-active { border-color: #34D399; background: rgba(52,211,153,.05); box-shadow: 0 0 0 1px #34D399; }
    .sp__planRadio { width: 18px; height: 18px; border-radius: 50%; border: 2px solid #c4cad1; flex-shrink: 0; position: relative; transition: border-color .15s; }
    .sp__planRow.is-active .sp__planRadio { border-color: #34D399; }
    .sp__planRow.is-active .sp__planRadio::after { content: ''; position: absolute; inset: 3px; border-radius: 50%; background: #34D399; }
    .sp__planName { font-size: 14.5px; font-weight: 600; color: #1a1f36; display: flex; align-items: center; gap: 7px; }
    .sp__planName em { font-style: normal; font-size: 10px; font-weight: 700; letter-spacing: .03em; text-transform: uppercase; color: #047857; background: rgba(52,211,153,.15); padding: 2px 7px; border-radius: 20px; }
    .sp__planMain { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
    .sp__planMeta { font-size: 11.5px; font-weight: 500; color: #8792a2; }
    .sp__planPrice { margin-left: auto; padding-left: 12px; font-size: 14.5px; font-weight: 600; color: #1a1f36; align-self: center; }
    .sp__note { margin: 12px 2px 0; font-size: 12px; font-weight: 500; color: #8792a2; line-height: 1.4; }

    /* Акция «today only $10» (видна только по чётным числам, см. promo.ts) */
    .sp__promo { display: flex; align-items: center; gap: 10px; margin: 0 0 22px; padding: 12px 14px; background: rgba(52,211,153,.1); border: 1px solid rgba(5,150,105,.28); border-radius: 10px; font-size: 13.5px; font-weight: 600; line-height: 1.45; color: #1a1f36; }
    .sp__promoFlame { font-size: 18px; line-height: 1; flex: 0 0 auto; }
    .sp__promo b { color: #059669; }
    .sp__promo [data-promo-timer] { color: #b45309; font-variant-numeric: tabular-nums; }
    .sp__planRow--promo .sp__planName em { color: #fff; background: #059669; }
    .sp__planWas { color: #8792a2; font-weight: 500; text-decoration: line-through; margin-right: 5px; font-size: 13px; }

    .sp__lines { border-top: 1px solid #e6e9ee; padding-top: 16px; display: flex; flex-direction: column; gap: 9px; }
    .sp__line { display: flex; align-items: baseline; justify-content: space-between; font-size: 14px; font-weight: 500; color: #4b5563; }
    .sp__line--muted { color: #8792a2; font-size: 13px; }
    .sp__line--total { margin-top: 5px; padding-top: 13px; border-top: 1px solid #e6e9ee; font-size: 15px; font-weight: 700; color: #1a1f36; }

    .sp__perks { list-style: none; margin: 24px 0 0; padding: 0; display: flex; flex-direction: column; gap: 9px; }
    .sp__perks li { display: flex; align-items: center; gap: 9px; font-size: 13px; font-weight: 500; color: #4b5563; }
    .sp__perks svg { color: #34D399; flex-shrink: 0; }

    .sp__continue { width: 100%; height: 48px; margin-top: 28px; font-family: inherit; font-size: 15px; font-weight: 600; color: #fff; background: #059669; border: none; border-radius: 8px; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 8px; box-shadow: 0 1px 2px rgba(0,0,0,.08); transition: background .15s, transform .1s; }
    .sp__continue:hover { background: #047857; }
    .sp__continue:active { transform: translateY(1px); }
    .sp__continue svg { transition: transform .15s; }
    .sp__continue:hover svg { transform: translateX(2px); }

    .sp__notify { margin-top: 24px; padding: 20px; border: 1px solid #e6e9ee; border-radius: 12px; background: #f9fafb; animation: spIn .24s ease; }
    @keyframes spIn { from { opacity: 0; transform: translateY(-5px); } to { opacity: 1; transform: translateY(0); } }
    .sp__notifyHead { display: flex; align-items: center; gap: 9px; font-size: 15px; font-weight: 700; color: #1a1f36; margin-bottom: 14px; }
    .sp__notifyHead svg { color: #D97706; flex: 0 0 auto; }
    .sp__notifyText { margin: 0; font-size: 13.5px; font-weight: 500; line-height: 1.5; color: #6b7280; }

    .sp__powered { display: flex; align-items: center; gap: 10px; margin-top: 32px; font-size: 12.5px; font-weight: 500; color: #aab0bb; }
    .sp__powered a { color: #aab0bb; transition: color .15s; }
    .sp__powered a:hover { color: #6b7280; }
    .sp__sep { opacity: .6; }

    @media (max-width: 480px) {
      .sp__wrap { padding: 36px 18px 40px; }
      .sp__back { margin-bottom: 28px; }
    }
  </style>

  <script>
    // Выбор тарифа обновляет суммы; ViewContent на загрузке; «Proceed to payment»
    // (оплата ещё не подключена) -> InitiateCheckout + блок сбора email; отправка
    // email -> Lead + успех. См. шапку файла про отсутствие бэкенда для email.
    import { isPromoActive, msUntilMidnight, formatCountdown } from '../scripts/promo';
    (function () {
      var ROLE: Record<string, string> = { sa: 'Sales Associate', broker: 'Broker' };
      var state = { role: 'sa', plan: '1 Month', price: 69 };

      function money(n: number) { return '$' + n + '.00'; }
      function setText(sel: string, val: string) { var e = document.querySelector(sel); if (e) { e.textContent = val; } }
      function each(sel: string, fn: (el: Element) => void) { Array.prototype.forEach.call(document.querySelectorAll(sel), fn); }

      function render() {
        var roleName = ROLE[state.role] || 'Sales Associate';
        var amt = money(state.price);
        setText('[data-linename]', roleName + ' · ' + state.plan);
        setText('[data-lineprice]', amt);
        setText('[data-total]', amt);
      }

      each('[data-plan]', function (b) {
        b.addEventListener('click', function () {
          each('[data-plan]', function (x) { x.classList.remove('is-active'); });
          b.classList.add('is-active');
          state.plan = b.getAttribute('data-plan') || '1 Month';
          state.price = Number(b.getAttribute('data-price')) || 69;
          render();
        });
      });

      render();

      // Акция «today only $10»: только по чётным числам (см. promo.ts). Раскрываем
      // промо-тариф и баннер, выбираем тариф (его клик сам обновит суммы) и тикаем
      // отсчёт до полуночи. Делаем это ДО ViewContent, чтобы аналитика поймала $10.
      if (isPromoActive()) {
        var promoRow = document.querySelector('[data-promo-row]') as HTMLElement | null;
        var promoBanner = document.querySelector('[data-promo-banner]') as HTMLElement | null;
        var promoTimer = document.querySelector('[data-promo-timer]') as HTMLElement | null;
        // Прячем обычный тариф «3 Months» ($89): по акции эти же 3 месяца идут за $10,
        // две строки «3 Months» рядом смотрелись бы противоречиво.
        var regular3m = document.querySelector('.sp__planRow[data-price="89"]') as HTMLElement | null;
        if (regular3m) { regular3m.hidden = true; }
        if (promoRow) { promoRow.hidden = false; promoRow.click(); }
        if (promoBanner) { promoBanner.hidden = false; }
        (function tick() {
          var ms = msUntilMidnight();
          if (ms <= 0) { location.reload(); return; }
          if (promoTimer) { promoTimer.textContent = formatCountdown(ms); }
          setTimeout(tick, 1000);
        })();
      }

      // Просмотр прайса на загрузке (fbq/ym - синхронные очереди, событие не теряется).
      try {
        var vc = { value: state.price, currency: 'USD', content_name: state.plan };
        console.log('[Meta] fbq track ViewContent', vc);
        (window as any).fbq && (window as any).fbq('track', 'ViewContent', vc);
      } catch (err) { /* пиксель ещё не загрузился */ }
      try {
        var vy = { plan: state.plan, role: state.role, price: state.price };
        console.log('[Yandex] ym reachGoal ViewContent', vy);
        (window as any).ym && (window as any).ym(109780177, 'reachGoal', 'ViewContent', vy);
      } catch (err) { /* метрика ещё не загрузилась */ }

      // «Proceed to payment»: намерение оформить -> InitiateCheckout (один раз);
      // оплаты пока нет -> показываем блок «оплатить пока нельзя».
      var icSent = false;
      var cont = document.querySelector('[data-continue]') as HTMLElement | null;
      var notify = document.querySelector('[data-notify]') as HTMLElement | null;
      if (cont && notify) {
        cont.addEventListener('click', function () {
          if (!icSent) {
            icSent = true;
            try {
              var ic = { value: state.price, currency: 'USD', content_name: state.plan };
              console.log('[Meta] fbq track InitiateCheckout', ic);
              (window as any).fbq && (window as any).fbq('track', 'InitiateCheckout', ic);
            } catch (err) { /* пиксель ещё не загрузился */ }
            try {
              var iy = { plan: state.plan, role: state.role, price: state.price };
              console.log('[Yandex] ym reachGoal InitiateCheckout', iy);
              (window as any).ym && (window as any).ym(109780177, 'reachGoal', 'InitiateCheckout', iy);
            } catch (err) { /* метрика ещё не загрузилась */ }
          }
          cont!.style.display = 'none';
          notify!.hidden = false;
          try { notify!.scrollIntoView({ block: 'nearest', behavior: 'smooth' }); } catch (err) { /* старые браузеры */ }
        });
      }

    })();
  </script>
</body>
</html>
