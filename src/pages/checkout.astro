---
// Checkout page - landing after the user picks a plan and presses «Get …».
// The order summary is filled from the URL query (role/plan/price), so the page
// is shareable/refresh-safe. On load it fires InitiateCheckout (Meta) + a
// `checkout` goal (Yandex) - reaching this page = starting checkout. The final
// «Buy» button fires the Purchase event into both pixels, then hands off to pay.
import Head from '../components/Head.astro';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <Head
    title="Checkout - Lingo7 Realty"
    description="Confirm your Lingo7 Realty order and complete your purchase."
    canonicalUrl="https://lingo7realty.com/checkout/"
    noindex={true}
  />
</head>
<body class="co-body">
  <header class="co-topbar">
    <div class="co-topbar__inner">
      <a href="/" class="logo">
        <img src="/favicon.svg" alt="Lingo7 Realty" class="logo__img" />
        <span class="logo__text">Lingo7 <span class="logo__accent">Realty</span></span>
      </a>
      <div class="co-topbar__secure">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
        Secure checkout
      </div>
    </div>
  </header>

  <main class="co-main">
    <div class="checkout">
      <div class="card checkout__card">
        <a class="checkout__back" href="/#stores">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
          <span>Back to plans</span>
        </a>
        <span class="eyebrow"><span class="pin"></span><span>Secure checkout</span></span>
        <h2 class="checkout__title">Confirm your <span class="accent">order</span></h2>

        <div class="checkout__order">
          <div class="co-line">
            <div class="co-line__main">
              <span class="co-line__name" data-co-name>Sales Associate &middot; 1 Month</span>
              <span class="co-line__desc">Florida Real Estate exam prep</span>
            </div>
            <span class="co-line__price" data-co-lineprice>$69</span>
          </div>
        </div>

        <ul class="checkout__incl">
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg><span>Full Sales Associate question bank</span></li>
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg><span>Realistic timed mock exams</span></li>
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg><span>Parallel translation, audio and spaced repetition built in</span></li>
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg><span><span data-co-access>1 Month</span> of full access</span></li>
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg><span>7-day money-back guarantee</span></li>
        </ul>

        <div class="checkout__totals">
          <div class="co-total-row"><span>Subtotal</span><span data-co-sub>$69</span></div>
          <div class="co-total-row co-total-row--grand"><span>Total due today</span><span data-co-total>$69</span></div>
        </div>
        <div class="plans-note">One-time payment &middot; no auto-renewal</div>

        <button class="cta checkout__buy" type="button" data-checkout-buy>
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
          <span>Buy</span> &middot; <span data-co-btnprice>$69</span>
        </button>
        <div class="guarantee"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><polyline points="9 12 11 14 15 10"></polyline></svg> <span>Get your money back within 7 days</span></div>
      </div>
    </div>
  </main>

  <footer class="co-foot">
    <span>&copy; 2026 Lingo7 Realty</span>
    <span class="co-foot__sep">&middot;</span>
    <a href="/terms/">Terms</a>
    <a href="/privacy/">Privacy</a>
  </footer>

  <script>
    // Сводку заказа берём из адреса (role/plan/price), заданных при клике «Get …».
    (function () {
      var ROLE_NAMES: Record<string, string> = { sa: 'Sales Associate', broker: 'Broker' };
      var q = new URLSearchParams(location.search);
      var plan = q.get('plan') || '1 Month';
      var price = Number(q.get('price')) || 69;
      var role = q.get('role') || 'sa';
      var roleName = ROLE_NAMES[role] || 'Sales Associate';
      var priceStr = '$' + price;

      function setText(sel: string, val: string) {
        var el = document.querySelector(sel);
        if (el) { el.textContent = val; }
      }
      setText('[data-co-name]', roleName + ' · ' + plan);
      setText('[data-co-lineprice]', priceStr);
      setText('[data-co-access]', plan);
      setText('[data-co-sub]', priceStr);
      setText('[data-co-total]', priceStr);
      setText('[data-co-btnprice]', priceStr);

      // Попадание на /checkout/ = начало оформления. Стандартное событие Meta
      // InitiateCheckout + цель Яндекс.Метрики «checkout» с параметрами заказа,
      // один раз при загрузке страницы. (Раньше слалось по клику «Get …» на
      // лендинге; перенесено сюда, чтобы не задваивать счёт.)
      try {
        var icParams = { value: price, currency: 'USD', content_name: plan };
        console.log('[Meta] fbq track InitiateCheckout', icParams);
        (window as any).fbq && (window as any).fbq('track', 'InitiateCheckout', icParams);
      } catch (err) { /* пиксель ещё не загрузился */ }
      try {
        var icYm = { plan: plan, role: role, price: price };
        console.log('[Yandex] ym reachGoal checkout', icYm);
        (window as any).ym && (window as any).ym(109780177, 'reachGoal', 'checkout', icYm);
      } catch (err) { /* метрика ещё не загрузилась */ }

      var buy = document.querySelector('[data-checkout-buy]');
      if (buy) {
        buy.addEventListener('click', function (e) {
          e.preventDefault();
          // Meta: финальная покупка.
          try {
            var fbqParams = { value: price, currency: 'USD', content_name: plan };
            console.log('[Meta] fbq track Purchase', fbqParams);
            (window as any).fbq && (window as any).fbq('track', 'Purchase', fbqParams);
          } catch (err) { /* пиксель ещё не загрузился */ }
          // Яндекс.Метрика: цель purchase.
          try {
            var ymParams = { plan: plan, role: role, price: price };
            console.log('[Yandex] ym reachGoal purchase', ymParams);
            (window as any).ym && (window as any).ym(109780177, 'reachGoal', 'purchase', ymParams);
          } catch (err) { /* метрика ещё не загрузилась */ }
          // TODO: подключить платёжный провайдер (редирект на оплату / виджет).
        });
      }
    })();
  </script>

  <style is:global>
    .co-body { background: #f4f6f8; min-height: 100vh; display: flex; flex-direction: column; }

    .co-topbar { background: rgba(255,255,255,0.92); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-bottom: 1px solid rgba(0,0,0,0.05); }
    .co-topbar__inner { max-width: 760px; margin: 0 auto; padding: 16px 24px; display: flex; align-items: center; justify-content: space-between; }
    .co-topbar .logo { display: flex; align-items: center; gap: 10px; }
    .co-topbar .logo__img { height: 32px; width: auto; }
    .co-topbar .logo__text { font-size: 19px; font-weight: 700; color: #1a1a2e; }
    .co-topbar .logo__accent { color: #34D399; }
    .co-topbar__secure { display: inline-flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 600; color: #6b7280; }
    .co-topbar__secure svg { color: #34D399; }

    .co-main { flex: 1; display: flex; align-items: flex-start; justify-content: center; padding: 48px 20px 56px; }

    .co-foot { display: flex; align-items: center; justify-content: center; gap: 14px; padding: 24px 20px 32px; font-size: 13px; font-weight: 500; color: #9aa0a8; }
    .co-foot a { color: #9aa0a8; transition: color .18s; }
    .co-foot a:hover { color: #34D399; }
    .co-foot__sep { opacity: .5; }

    @media (max-width: 768px) {
      .co-topbar__inner { padding: 14px 16px; }
      .co-topbar__secure { display: none; }
      .co-main { padding: 28px 14px 40px; }
    }
  </style>
</body>
</html>
