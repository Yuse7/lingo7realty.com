---

<BaseLayout
  title="Lingo7 Realty - Pass the Florida Real Estate Exam, No Language Barrier"
  description="Florida Real Estate exam prep built for people whose English isn't their first language: an interactive textbook, adaptive tests, and term flashcards with parallel translation, audio, and spaced repetition. The adaptive engine maps your fastest route to a passing score. Covers national + Florida law, in 10 languages."
  keywords="Florida real estate exam, real estate license, Sales Associate exam, real estate exam prep, real estate exam for immigrants, real estate vocabulary, practice test, national exam, state exam, real estate math, adaptive exam prep, Lingo7 Realty"
  canonicalUrl="https://lingo7realty.com/"
>
  <HeroSection />
  <TrustStrip />
  <Compare />
  <Library />
  <SpacedRepetition />
  <MathSection />
  <Reviews />
  <Faq />
  <FinalCta />
  <Modals />
