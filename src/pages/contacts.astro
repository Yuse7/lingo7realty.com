---
import LegalLayout from '../layouts/LegalLayout.astro';
---

<LegalLayout
  title="Contact Us - Lingo7 Realty"
  description="Contact Lingo7 Realty - support, partnerships, and legal information."
  canonicalUrl="https://lingo7realty.com/contacts/"
  noindex={true}
>
  <section class="contacts">
    <h1>Contact Us</h1>
    <p class="contacts__subtitle">We're here and always happy to help.</p>

    <div class="contacts__cards">
      <div class="contacts__card">
        <div class="contacts__card-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#34D399" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </div>
        <div class="contacts__card-content">
          <h3>Support</h3>
          <p>Questions, feedback, and bug reports</p>
          <a href="mailto:support@lingo7realty.com">support@lingo7realty.com</a>
        </div>
      </div>

      <div class="contacts__card">
        <div class="contacts__card-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#34D399" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
        </div>
        <div class="contacts__card-content">
          <h3>Partnerships</h3>
          <p>Partnerships, advertising, and proposals</p>
          <a href="mailto:support@lingo7realty.com">support@lingo7realty.com</a>
        </div>
      </div>

      <div class="contacts__card">
        <div class="contacts__card-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#34D399" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div class="contacts__card-content">
          <h3>Legal Information</h3>
          <p><a href="/terms/">Terms of Service</a></p>
          <p><a href="/privacy/">Privacy Policy</a></p>
        </div>
      </div>
    </div>
  </section>
</LegalLayout>

<style>
  .contacts {
    padding: 160px 40px 80px;
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }
  .contacts h1 {
    font-size: 36px; font-weight: 800; margin-bottom: 16px;
  }
  .contacts__subtitle {
    font-size: 18px; color: #666; line-height: 1.6; margin-bottom: 48px;
  }
  .contacts__cards {
    display: flex;
    flex-direction: column;
    gap: 20px;
    text-align: left;
  }
  .contacts__card {
    background: #f9fafb;
    border: 1px solid #eee;
    border-radius: 16px;
    padding: 28px;
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }
  .contacts__card-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: rgba(52, 211, 153, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .contacts__card-content h3 {
    font-size: 16px; font-weight: 700; margin-bottom: 6px;
  }
  .contacts__card-content p {
    font-size: 15px; color: #666; line-height: 1.5; margin-bottom: 4px;
  }
  .contacts__card-content a {
    color: #34D399; font-weight: 600; text-decoration: underline;
    text-underline-offset: 2px;
  }
  .contacts__card-content a:hover {
    color: #2bc48a;
  }

  @media (max-width: 768px) {
    .contacts { padding: 110px 16px 60px; }
    .contacts h1 { font-size: 28px; }
    .contacts__subtitle { font-size: 16px; }
    .contacts__card { padding: 20px; }
  }
</style>
