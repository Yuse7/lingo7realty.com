---
// Общий «chrome» для страниц покупательской воронки (выбор тарифа /plans/ +
// оформление /checkout/): светлая тема, узкий topbar с «Secure checkout» и
// минимальный футер. Лендинговые Header/Footer тут НЕ используются - это
// сфокусированный шаг воронки. Стили самих карточек (.pricing / .checkout*)
// лежат в global.css; здесь - только обвязка страницы.
import Head from '../components/Head.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
  noindex?: boolean;
}
const { title, description, canonicalUrl, noindex = true } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <Head title={title} description={description} canonicalUrl={canonicalUrl} noindex={noindex} />
</head>
<body class="co-body">
  <header class="co-topbar">
    <div class="co-topbar__inner">
      <a href="/" class="logo">
        <img src="/favicon.svg" alt="Lingo7 Realty" class="logo__img" />
        <span class="logo__text">Lingo7 <span class="logo__accent">Realty</span></span>
      </a>
      <div class="co-topbar__secure">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
        Secure checkout
      </div>
    </div>
  </header>

  <main class="co-main">
    <slot />
  </main>

  <footer class="co-foot">
    <span>&copy; 2026 Lingo7 Realty</span>
    <span class="co-foot__sep">&middot;</span>
    <a href="/terms/">Terms</a>
    <a href="/privacy/">Privacy</a>
  </footer>

  <style is:global>
    .co-body { background: #f4f6f8; min-height: 100vh; display: flex; flex-direction: column; }

    .co-topbar { background: rgba(255,255,255,0.92); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-bottom: 1px solid rgba(0,0,0,0.05); }
    .co-topbar__inner { max-width: 760px; margin: 0 auto; padding: 16px 24px; display: flex; align-items: center; justify-content: space-between; }
    .co-topbar .logo { display: flex; align-items: center; gap: 10px; }
    .co-topbar .logo__img { height: 32px; width: auto; }
    .co-topbar .logo__text { font-size: 19px; font-weight: 700; color: #1a1a2e; }
    .co-topbar .logo__accent { color: #34D399; }
    .co-topbar__secure { display: inline-flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 600; color: #6b7280; }
    .co-topbar__secure svg { color: #34D399; }

    .co-main { flex: 1; display: flex; align-items: flex-start; justify-content: center; padding: 48px 20px 56px; }

    .co-foot { display: flex; align-items: center; justify-content: center; gap: 14px; padding: 24px 20px 32px; font-size: 13px; font-weight: 500; color: #9aa0a8; }
    .co-foot a { color: #9aa0a8; transition: color .18s; }
    .co-foot a:hover { color: #34D399; }
    .co-foot__sep { opacity: .5; }

    @media (max-width: 768px) {
      .co-topbar__inner { padding: 14px 16px; }
      .co-topbar__secure { display: none; }
      .co-main { padding: 28px 14px 40px; }
    }
  </style>
</body>
</html>
