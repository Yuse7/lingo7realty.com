---
// Landing header: logo, nav, language switcher (desktop + mobile), login, and
// the mobile slide-down menu. Interactivity lives in src/scripts/main.ts.
---
<header class="header">
  <div class="container header__inner">
    <a href="/" class="logo">
      <img src="/favicon.svg" alt="Lingo7 Realty" class="logo__img" />
      <span class="logo__text" data-i18n="header.logo">Lingo7 <span class="logo__accent">Realty</span></span>
    </a>
    <nav class="nav">
      <a href="#library" class="nav__link" data-i18n="header.nav-library">Tools</a>
      <a href="#reviews" class="nav__link" data-i18n="header.nav-reviews">Reviews</a>
      <a href="#faq" class="nav__link" data-i18n="header.nav-faq">FAQ</a>
    </nav>
    <div class="header__right">
      <a href="#" class="header__login" data-login data-i18n="header.login">Log in</a>
      <a href="/plans/" class="btn btn--primary header__cta header__cta--sm" data-i18n="header.cta"><span class="header__cta-long">See plans &amp; pricing</span><span class="header__cta-brief">See plans</span></a>
      <button class="burger" id="burger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<div class="mobile-menu" id="mobileMenu">
  <a href="#library" class="mobile-menu__link" data-i18n="mobilemenu.tools">Tools</a>
  <a href="#reviews" class="mobile-menu__link" data-i18n="mobilemenu.reviews">Reviews</a>
  <a href="#faq" class="mobile-menu__link" data-i18n="mobilemenu.faq">FAQ</a>
  <a href="#" class="mobile-menu__link mobile-menu__login" data-login data-i18n="mobilemenu.login">Log in</a>
</div>
