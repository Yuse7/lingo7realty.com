        prTitle: '现在试试', prQ: '提示：5% = 0.05。', prRight: '完全正确！$250,000 × 0.05 = $12,500。', prWrong: '差一点。5% = 0.05，所以 $250,000 × 0.05 = $12,500。' },
      ar: { sec: 'الرياضيات · العمولة', prob: 'يُباع منزل بمبلغ 250,000 دولار. نسبة العمولة 6٪. ما هي العمولة الإجمالية؟', ans: 'إجمالي العمولة',
        plainKicker: 'بكلمات بسيطة', plain: 'يحصل الوكيل على جزء صغير من سعر البيع. كل ما علينا هو معرفة حجم هذا الجزء.',
        barCap: '6٪ تعني 6 دولارات من كل 100 دولار.', cap1: 'ابدأ بسعر البيع ونسبة العمولة.',
        convCap: 'حوّل 6٪ إلى رقم - حرّك الفاصلة منزلتين إلى اليسار. انقر للإعادة.', cap2: 'الآن فقط اضرب. هذه هي الحيلة كلها.',
        mistakeT: 'خطأ شائع', mistake: 'لا تضرب في 6. حوّل 6٪ أولاً إلى 0.06 ثم اضرب.',
        prTitle: 'الآن جرّب بنفسك', prQ: 'تلميح: 5٪ = 0.05.', prRight: 'بالضبط! 250,000 × 0.05 = 12,500 دولار.', prWrong: 'تقريباً. 5٪ = 0.05، أي 250,000 × 0.05 = 12,500 دولار.' },
      tl: { sec: 'Matematika · Komisyon', prob: 'Naibenta ang isang bahay sa halagang $250,000. Ang komisyon ay 6%. Magkano ang kabuuang komisyon?', ans: 'Kabuuang komisyon',
        plainKicker: 'Sa simpleng salita', plain: 'Kumikita ang ahente ng maliit na bahagi ng presyo ng benta. Kailangan lang nating malaman kung gaano kalaki ang bahaging iyon.',
        barCap: 'Ang 6% ay $6 sa bawat $100.', cap1: 'Magsimula sa presyo ng benta at sa rate ng komisyon.',
        convCap: 'Gawing numero ang 6% - igalaw ang tuldok ng 2 hakbang pakaliwa. I-tap para ulitin.', cap2: 'Ngayon, i-multiply na lang. Iyon na ang buong trick.',
        mistakeT: 'Karaniwang pagkakamali', mistake: 'Huwag i-multiply sa 6. Gawin munang 0.06 ang 6%, tapos i-multiply.',
        prTitle: 'Subukan mo ngayon', prQ: 'Pahiwatig: 5% = 0.05.', prRight: 'Tama! $250,000 × 0.05 = $12,500.', prWrong: 'Halos. 5% = 0.05, kaya $250,000 × 0.05 = $12,500.' }
    };

    function q(name: string) { return root.querySelector('[data-el="' + name + '"]') as HTMLElement | null; }

    // Язык демо: ?lang из URL → язык браузера → испанский (единый resolveLang, см. lang.ts).
    var curLang = 'es', parallelOn = true;
    var l = resolveLang();
    if (l === 'off' || l === 'en') { parallelOn = false; } else if (LMETA[l]) { curLang = l; }
    var langLabel = q('langLabel'), langChip = q('langChip'), langMenu = q('langMenu');
    if (langLabel) { langLabel.textContent = parallelOn ? LMETA[curLang].label : (l === 'en' ? 'EN' : 'Translate'); }
    if (!parallelOn && langChip) { langChip.style.background = '#fff'; langChip.style.color = '#047857'; langChip.style.borderColor = 'rgba(52,211,153,.55)'; }

    var practiceState: string | null = null;
    var practicePicked = -1;

    function applyLang() {
      var dir = LMETA[curLang].dir, t = T[curLang];
      var sec = q('secTR'); if (sec) { sec.textContent = t.sec; sec.setAttribute('dir', dir); }
      var pb = q('probBadge'); if (pb) { pb.textContent = LMETA[curLang].label; }
      var pt = q('probText'); if (pt) { pt.textContent = t.prob; pt.setAttribute('dir', dir); }
      var ptr = q('probTR'); if (ptr) { ptr.style.textAlign = (dir === 'rtl') ? 'right' : 'left'; }
      var L = parallelOn ? t : EN, sdir = parallelOn ? dir : 'ltr';
      function set(name: string, val: string, applyDir: boolean) { var el = q(name); if (!el) { return; } el.textContent = val; if (applyDir) { el.setAttribute('dir', sdir); el.style.textAlign = (sdir === 'rtl') ? 'right' : ''; } }
      set('plainKicker', L.plainKicker, false);
      set('plainText', L.plain, true);
      set('barCap', L.barCap, true);
      set('cap1', L.cap1, true);
      set('convCap', L.convCap, true);
      set('cap2', L.cap2, true);
      set('mistakeT', L.mistakeT, false);
      set('mistakeText', L.mistake, true);
      var ans = q('ansLabel'); if (ans) { ans.textContent = L.ans || (parallelOn ? t.ans : 'Total commission'); }
      var prT = q('prTitle'); if (prT) { prT.textContent = L.prTitle; }
      var prB = q('prBadge'); if (prB) { prB.textContent = LMETA[curLang].label; }
      var pq = q('prQText'); if (pq) { pq.textContent = t.prQ; if (parallelOn) { pq.setAttribute('dir', dir); pq.style.textAlign = (dir === 'rtl') ? 'right' : ''; } }
      if (practiceState) { showPracticeFeedback(); }
      root.querySelectorAll<HTMLElement>('.tr-line').forEach(function (e) { e.style.display = parallelOn ? '' : 'none'; });
    }
    function buildLangMenu() {
      if (!langMenu) { return; }
      langMenu.innerHTML = '';
      LANG_ORDER.forEach(function (code) {
        var m = LMETA[code];
        var b = document.createElement('button');
        b.className = 'langOpt';
        if (code === 'ar') { b.setAttribute('dir', 'rtl'); }
        var active = (code === 'off') ? !parallelOn : (parallelOn && curLang === code);
        b.innerHTML = '<span>' + m.native + '</span><span style="color:#34D399; font-weight:800; display:' + (active ? 'inline' : 'none') + ';">✓</span>';
        b.onclick = function (e) { e.stopPropagation(); pickLang(code); };
        langMenu!.appendChild(b);
      });
    }
    function toggleLangMenu(e: Event) {
      e.stopPropagation();
      if (!langMenu) { return; }
      if (langMenu.style.display === 'block') { langMenu.style.display = 'none'; return; }
      buildLangMenu(); langMenu.style.display = 'block';
    }
    function pickLang(code: string) {
      if (code === 'off') { parallelOn = false; } else { parallelOn = true; curLang = code; }
      applyLang();
      if (langLabel) { langLabel.textContent = parallelOn ? LMETA[curLang].label : 'Translate'; }
      if (langChip) {
        if (parallelOn) { langChip.style.background = '#34D399'; langChip.style.color = '#fff'; langChip.style.borderColor = '#34D399'; }
        else { langChip.style.background = '#fff'; langChip.style.color = '#047857'; langChip.style.borderColor = 'rgba(52,211,153,.55)'; }
      }
      if (langMenu) { langMenu.style.display = 'none'; }
    }

    // decimal-hop replay
    function playConv() {
      var c = q('conv'); if (!c) { return; }
      c.classList.remove('play'); void c.offsetWidth; c.classList.add('play');
    }

    // ── mini practice (active recall) ──
    var PR_OPTS = ['$10,000', '$12,500', '$15,000'];
    var PR_CORRECT = 1;
    function renderPractice() {
      var box = q('prOpts'); if (!box) { return; }
      box.innerHTML = '';
      PR_OPTS.forEach(function (v, i) {
        var b = document.createElement('button');
        b.className = 'pr-opt mono';
        b.setAttribute('data-i', String(i));
        b.textContent = v;
        b.style.cssText = 'flex:1; border:1.5px solid #e3e7e9; background:#fff; color:#1a1a2e; font-family:inherit; font-size:14px; font-weight:700; padding:11px 4px; border-radius:12px; cursor:pointer; transition:all .15s;';
        b.onclick = function (e) { e.stopPropagation(); checkPractice(i); };
        box.appendChild(b);
      });
    }
    function checkPractice(i: number) {
      practicePicked = i;
      practiceState = (i === PR_CORRECT) ? 'right' : 'wrong';
      var btns = root.querySelectorAll<HTMLElement>('[data-el="prOpts"] .pr-opt');
      btns.forEach(function (b, idx) {
        if (idx === PR_CORRECT) { b.style.borderColor = '#34D399'; b.style.background = 'rgba(52,211,153,.12)'; b.style.color = '#047857'; }
        else if (idx === i) { b.style.borderColor = '#d05656'; b.style.background = '#fdecec'; b.style.color = '#c2410c'; }
        else { b.style.borderColor = '#e3e7e9'; b.style.background = '#fff'; b.style.color = '#1a1a2e'; }
      });
      showPracticeFeedback();
    }
    function showPracticeFeedback() {
      if (!practiceState) { return; }
      var L = parallelOn ? T[curLang] : EN, dir = parallelOn ? LMETA[curLang].dir : 'ltr';
      var fb = q('prFeedback'); if (!fb) { return; }
      var ok = practiceState === 'right';
      fb.style.display = 'block';
      fb.style.background = ok ? 'rgba(52,211,153,.1)' : '#fff7f5';
      fb.style.color = ok ? '#047857' : '#8a6552';
      fb.style.border = ok ? '1px solid rgba(52,211,153,.3)' : '1px solid #f7d9cf';
      fb.setAttribute('dir', dir); fb.style.textAlign = (dir === 'rtl') ? 'right' : '';
      fb.innerHTML = '<span style="font-weight:800; margin-right:5px;">' + (ok ? '✓' : '→') + '</span>' + (ok ? L.prRight : L.prWrong);
    }

    // wire events (former inline on* handlers)
    if (langChip) { langChip.addEventListener('click', toggleLangMenu); }
    if (langMenu) { langMenu.addEventListener('click', function (e) { e.stopPropagation(); }); }
    var conv = q('conv'); if (conv) { conv.addEventListener('click', function () { playConv(); }); }
    document.addEventListener('click', function () { if (langMenu) { langMenu.style.display = 'none'; } });

    applyLang();
    renderPractice();
    // gentle auto-demo of the conversion shortly after load
    setTimeout(playConv, 600);
  }

  document.querySelectorAll<HTMLElement>('[data-screen="math"]').forEach(initMath);
</script>
