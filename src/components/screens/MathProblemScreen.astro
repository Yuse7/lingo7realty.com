---
// Inline demo screen: exam math problem with parallel translation, step-by-step
// solution and a mini practice. Was public/screens/Math Problem Screen.html
// (an iframe). Inlined into the light DOM so Yandex Webvisor can record it.
//
// PATTERN (shared by all inline screens):
//  - root <div data-screen="math"> ; language is read at runtime from ?lang
//  - all former id="x" → data-el="x"; JS reaches them via root.querySelector
//  - styles in one <style is:global> block, every selector prefixed with
//    [data-screen="math"] (isolates from other screens AND covers elements
//    created in JS, which Astro's scoped CSS would miss); @keyframes prefixed
//  - script is a module (runs once); initMath(root) holds all state/functions
//    in a closure and is mapped over every [data-screen="math"] instance
---
<div class="screen" data-screen="math" style="width:320px; height:600px; overflow:hidden; border-radius:24px; background:#fff; position:relative; color:#1a1a2e; font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; box-shadow:0 12px 40px rgba(0,0,0,.12); display:flex; flex-direction:column;">

  <!-- Header -->
  <div style="display:flex; align-items:center; gap:9px; padding:16px 16px 13px; border-bottom:1px solid #eef0f0; flex-shrink:0;">
    <span style="font-size:20px; line-height:1; flex-shrink:0;">🔢</span>
    <span style="flex:1; min-width:0; line-height:1.15;">
      <span style="display:block; font-size:14px; font-weight:700; color:#1a1a2e;">Math · Commission</span>
      <span data-el="secTR" class="tr-line" style="display:block; font-size:11px; color:#a3a8af; margin-top:1px;"></span>
    </span>
    <div style="position:relative; flex-shrink:0;">
      <button data-el="langChip" title="Translation language" style="display:flex; align-items:center; gap:4px; border:1.5px solid #34D399; background:#34D399; color:#fff; font-family:inherit; font-size:11px; font-weight:700; padding:0 9px; height:28px; border-radius:999px; cursor:pointer; white-space:nowrap;">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><line x1="3" y1="12" x2="21" y2="12"></line><path d="M12 3a14 14 0 0 1 0 18a14 14 0 0 1 0-18z"></path></svg>
        <span data-el="langLabel">RU</span><span style="font-size:8px;">▾</span>
      </button>
      <div data-el="langMenu" style="display:none; position:absolute; top:calc(100% + 6px); right:0; background:#fff; border:1px solid #eef0f0; border-radius:13px; box-shadow:0 8px 26px rgba(26,26,46,.18); padding:5px; min-width:170px; max-height:420px; overflow-y:auto; z-index:60;"></div>
    </div>
  </div>

  <!-- Body -->
  <div class="body-scroll" style="flex:1; min-height:0; overflow-y:auto; padding:18px 20px 18px;">

    <!-- Problem statement -->
    <div style="font-size:10px; font-weight:800; letter-spacing:.12em; text-transform:uppercase; color:#34D399; margin-bottom:9px;">Problem</div>
    <p style="margin:0; font-size:16px; font-weight:700; line-height:1.45; color:#1a1a2e;">A home sells for $250,000. The commission rate is 6%. What is the total commission?</p>
    <p data-el="probTR" class="tr-line" style="margin:9px 0 0; font-size:12.5px; line-height:1.5; color:#a3a8af;"><span data-el="probBadge" class="ru-badge">RU</span><span data-el="probText"></span></p>

    <!-- In plain words -->
    <div style="margin-top:16px; background:#f0fdf4; border:1px solid rgba(52,211,153,.25); border-radius:14px; padding:13px 15px;">
      <div style="display:flex; align-items:center; gap:7px; margin-bottom:6px;">
        <span style="font-size:14px;">💡</span>
        <span data-el="plainKicker" style="font-size:11px; font-weight:800; letter-spacing:.04em; text-transform:uppercase; color:#047857;">In plain words</span>
      </div>
      <p data-el="plainText" style="margin:0; font-size:13.5px; line-height:1.5; color:#2b2f3a;"></p>
    </div>

    <!-- Percentage visual -->
    <div style="margin-top:16px;">
      <div style="position:relative; height:30px; background:#eef0f0; border-radius:9px; overflow:hidden;">
        <div style="position:absolute; left:0; top:0; bottom:0; width:6%; background:linear-gradient(135deg,#34D399,#059669);"></div>
        <span style="position:absolute; right:11px; top:50%; transform:translateY(-50%); font-size:12px; font-weight:700; color:#9aa1a0;" class="mono">$250,000</span>
      </div>
      <div style="display:flex; align-items:center; gap:6px; margin-top:7px;">
        <span style="width:10px; height:10px; border-radius:3px; background:#34D399; flex-shrink:0;"></span>
        <span data-el="barCap" style="font-size:11.5px; color:#8a909a; line-height:1.35;"></span>
      </div>
    </div>

    <!-- Divider -->
    <div style="height:1px; background:#eef0f0; margin:18px 0 14px;"></div>

    <!-- Solution -->
    <div style="font-size:10px; font-weight:800; letter-spacing:.12em; text-transform:uppercase; color:#9aa1a0; margin-bottom:12px;">Solution</div>

    <div style="display:flex; flex-direction:column; gap:14px;">
      <!-- Step 1 -->
      <div>
        <div style="display:flex; align-items:center; gap:12px;">
          <span style="flex-shrink:0; width:22px; height:22px; border-radius:50%; background:#f3f5f7; color:#6b7280; font-size:11px; font-weight:700; display:flex; align-items:center; justify-content:center;">1</span>
          <div style="flex:1; background:#f3f5f7; border-radius:12px; padding:13px 15px; font-size:16px; font-weight:600; color:#2b2f3a;" class="mono">$250,000 × 6%</div>
        </div>
        <div data-el="cap1" class="step-cap"></div>
      </div>

      <!-- Conversion (animated) -->
      <div>
        <div style="display:flex; align-items:center; gap:12px;">
          <span style="flex-shrink:0; width:22px; height:22px; border-radius:50%; background:#fef3c7; color:#b45309; font-size:11px; font-weight:700; display:flex; align-items:center; justify-content:center;">★</span>
          <div data-el="conv" class="conv" style="position:relative; flex:1; background:#fffdf5; border:1px solid #fde9b8; border-radius:12px; padding:11px 15px; cursor:pointer; display:flex; align-items:center; gap:12px; overflow:hidden;">
            <span style="font-size:17px; font-weight:800; color:#1a1a2e;" class="mono">6%</span>
            <svg width="20" height="14" viewBox="0 0 24 14" fill="none" stroke="#caa53a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="2" y1="7" x2="20" y2="7"></line><polyline points="14 2 20 7 14 12"></polyline></svg>
            <span class="conv-to mono" style="font-size:17px; font-weight:800; color:#047857;">0.06</span>
            <span class="hopdot"></span>
            <span style="margin-left:auto; font-size:10px; color:#caa53a; display:flex; align-items:center; gap:3px;">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#caa53a" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"></polyline><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path></svg>
            </span>
          </div>
        </div>
        <div data-el="convCap" class="step-cap"></div>
      </div>

      <!-- Step 2 -->
      <div>
        <div style="display:flex; align-items:center; gap:12px;">
          <span style="flex-shrink:0; width:22px; height:22px; border-radius:50%; background:#f3f5f7; color:#6b7280; font-size:11px; font-weight:700; display:flex; align-items:center; justify-content:center;">2</span>
          <div style="flex:1; background:#f3f5f7; border-radius:12px; padding:13px 15px; font-size:16px; font-weight:600; color:#2b2f3a;" class="mono">= $250,000 × 0.06</div>
        </div>
        <div data-el="cap2" class="step-cap"></div>
      </div>

      <!-- Step 3 - answer -->
      <div style="display:flex; align-items:center; gap:12px;">
        <span style="flex-shrink:0; width:22px; height:22px; border-radius:50%; background:#34D399; color:#fff; font-size:11px; font-weight:700; display:flex; align-items:center; justify-content:center;">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
        </span>
        <div style="flex:1; background:rgba(52,211,153,.12); border:1px solid rgba(52,211,153,.32); border-radius:12px; padding:13px 15px;">
          <div style="font-size:20px; font-weight:800; color:#047857;" class="mono">= $15,000</div>
          <div data-el="ansLabel" style="font-size:11px; font-weight:600; color:#059669; margin-top:2px;">Total commission</div>
        </div>
      </div>
    </div>

    <!-- Common mistake -->
    <div style="margin-top:18px; display:flex; gap:10px; background:#fff7f5; border:1px solid #f7d9cf; border-radius:14px; padding:12px 14px;">
      <span style="font-size:14px; flex-shrink:0; line-height:1.3;">⚠️</span>
      <div>
        <div data-el="mistakeT" style="font-size:11.5px; font-weight:800; color:#c2410c; margin-bottom:3px;">Common mistake</div>
        <p data-el="mistakeText" style="margin:0; font-size:12.5px; line-height:1.45; color:#8a6552;"></p>
      </div>
    </div>

    <!-- Mini practice -->
    <div style="margin-top:18px; background:#fff; border:1.5px solid #34D399; border-radius:16px; padding:14px 15px 15px; box-shadow:0 4px 16px rgba(52,211,153,.12);">
      <div style="display:flex; align-items:center; gap:7px; margin-bottom:8px;">
        <span style="font-size:14px;">✍️</span>
        <span data-el="prTitle" style="font-size:11px; font-weight:800; letter-spacing:.04em; text-transform:uppercase; color:#047857;">Now you try</span>
      </div>
      <p style="margin:0; font-size:14px; font-weight:700; line-height:1.4; color:#1a1a2e;">Same home - but the rate is <span style="color:#047857;">5%</span>. What is the commission?</p>
      <p data-el="prQTR" class="tr-line" style="margin:6px 0 0; font-size:12px; line-height:1.45; color:#a3a8af;"><span data-el="prBadge" class="ru-badge">RU</span><span data-el="prQText"></span></p>
      <div data-el="prOpts" style="display:flex; gap:8px; margin-top:12px;"></div>
      <div data-el="prFeedback" style="display:none; margin-top:11px; padding:10px 13px; border-radius:11px; font-size:12.5px; line-height:1.45;"></div>
    </div>

  </div>

</div>

<style is:global>
  [data-screen="math"] .ru-badge { display: inline-flex; align-items: center; font-size: 8.5px; font-weight: 800; letter-spacing: .04em; color: #047857; background: rgba(52,211,153,.14); border-radius: 4px; padding: 1px 5px; margin-right: 6px; vertical-align: middle; position: relative; top: -1px; }
  [data-screen="math"] .mono { font-variant-numeric: tabular-nums; }
  [data-screen="math"] .langOpt { display: flex; align-items: center; justify-content: space-between; gap: 10px; width: 100%; border: none; background: none; cursor: pointer; font-family: inherit; font-size: 12.5px; font-weight: 600; color: #1a1a2e; padding: 0 10px; min-height: 36px; line-height: 1.15; border-radius: 9px; text-align: left; }
  [data-screen="math"] .langOpt:hover { background: #f3f5f7; }
  [data-screen="math"] [data-el="langMenu"]::-webkit-scrollbar { width: 0; }
  [data-screen="math"] .body-scroll::-webkit-scrollbar { width: 0; }
  [data-screen="math"] .step-cap { font-size: 11.5px; color: #8a909a; line-height: 1.35; margin: 5px 0 0 34px; }
  /* decimal-hop animation */
  [data-screen="math"] .hopdot { position: absolute; width: 9px; height: 9px; border-radius: 50%; background: #f5b301; top: 6px; left: 16px; opacity: 0; }
  [data-screen="math"] .conv.play .hopdot { animation: math-hop 1.5s ease-in-out forwards; }
  @keyframes math-hop {
    0%   { left: 20px; top: 6px; opacity: 0; }
    8%   { opacity: 1; }
    25%  { left: 52px; top: -8px; }
    42%  { left: 84px; top: 6px; }
    58%  { left: 84px; top: -8px; }
    75%  { left: 116px; top: 6px; }
    92%  { opacity: 1; }
    100% { left: 116px; top: 6px; opacity: 0; }
  }
  [data-screen="math"] .conv.play .conv-to { animation: math-pop 1.5s ease forwards; }
  @keyframes math-pop { 0%,55% { color: #c0c5c9; transform: scale(.96); } 78% { color: #047857; transform: scale(1.08); } 100% { color: #047857; transform: scale(1); } }
</style>

<script>
  import { resolveLang } from '../../scripts/lang';

  function initMath(root: HTMLElement) {
