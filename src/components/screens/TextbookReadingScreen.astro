    // ════════════ Language application ════════════
    function applyLang() {
      var L = I18N[curLang], dir = LMETA[curLang].dir;
      function setLine(name: string, val: string) { var el = q(name); if (!el) { return; } el.textContent = val; el.setAttribute('dir', dir); }
      setLine('tTR', L.t); setLine('h2TR', L.h2); setLine('h3TR', L.h3); setLine('figCap', L.figCap);
      var chips = CHIP_I18N[curLang] || {};
      root.querySelectorAll<HTMLElement>('.figchip-tr').forEach(function (el) {
        el.textContent = chips[el.getAttribute('data-chip') || ''] || '';
        el.setAttribute('dir', dir);
      });
      (['p1', 'p2', 'p3', 'p4', 'p5'] as const).forEach(function (k) {
        var el = q(k + 'TR');
        if (!el) { return; }
        el.innerHTML = renderSegs(L[k]); el.setAttribute('dir', dir);
        el.removeAttribute('data-rw');
      });
      root.querySelectorAll<HTMLElement>('.ru-line').forEach(function (e) { e.style.display = parallelOn ? '' : 'none'; });
    }
    function buildLangMenu() {
      var menu = q('langMenu');
      if (!menu) { return; }
      menu.innerHTML = '';
      LANG_ORDER.forEach(function (code) {
        var m = LMETA[code];
        var b = document.createElement('button');
        b.className = 'langOpt';
        if (code === 'ar') { b.setAttribute('dir', 'rtl'); }
        var active = (code === 'off') ? !parallelOn : (parallelOn && curLang === code);
        b.innerHTML = '<span>' + m.native + '</span><span class="langTick" style="color:#34D399; font-weight:800; display:' + (active ? 'inline' : 'none') + ';">✓</span>';
        b.onclick = function (e) { e.stopPropagation(); pickLang(code); };
        menu!.appendChild(b);
      });
    }
    function toggleLangMenu(e: Event) {
      e.stopPropagation();
      var m = q('langMenu');
      if (!m) { return; }
      if (m.style.display === 'block') { m.style.display = 'none'; return; }
      buildLangMenu(); m.style.display = 'block';
    }
    function pickLang(code: string) {
      if (code === 'off') { parallelOn = false; }
      else { parallelOn = true; curLang = code; }
      applyLang();
      var chip = q('langChip'); var lbl = q('langLabel');
      if (lbl) { lbl.textContent = parallelOn ? LMETA[curLang].label : 'Translate'; }
      if (chip) {
        if (parallelOn) { chip.style.background = '#34D399'; chip.style.color = '#fff'; chip.style.borderColor = '#34D399'; }
        else { chip.style.background = '#fff'; chip.style.color = '#047857'; chip.style.borderColor = 'rgba(52,211,153,.55)'; }
      }
      if (!parallelOn) { clearHl(); var wb = q('wbar'); if (wb) { wb.style.display = 'none'; } }
      var menu = q('langMenu'); if (menu) { menu.style.display = 'none'; }
      // notify the page that the demo language changed
      root.dispatchEvent(new CustomEvent('l7:langPicked', { bubbles: true, detail: { lang: parallelOn ? curLang : 'off' } }));
    }

