---
// Inline demo screen: interactive textbook page with parallel translation,
// tap-to-translate words, a word-card bottom sheet, read-aloud auto mode and a
// bookmark. Was public/screens/Textbook Reading Screen.html (an iframe).
// Inlined into the light DOM so Yandex Webvisor can record it.
//
// PATTERN (shared by all inline screens):
//  - root <div data-screen="textbook"> ; language is read at runtime from ?lang
//  - all former id="x" → data-el="x"; JS reaches them via root.querySelector
//  - styles in one <style is:global> block, every selector prefixed with
//    [data-screen="textbook"] (isolates from other screens AND covers elements
//    created in JS, which Astro's scoped CSS would miss); @keyframes prefixed
//  - script is a module (runs once); initTextbook(root) holds all state/functions
//    in a closure and is mapped over every [data-screen="textbook"] instance
//  - demo auto-play mode is opt-in via the `demo` prop (was ?demo=1); it listens
//    for l7:play / l7:pause CustomEvents on root instead of window postMessage
const { demo = false } = Astro.props;
---
<div class="book" data-screen="textbook" data-demo={demo ? '1' : undefined} style="width:320px; height:600px; overflow:hidden; border-radius:24px; background:#fff; position:relative; color:#1a1a2e; font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; box-shadow:0 12px 40px rgba(0,0,0,.12); display:flex; flex-direction:column;">

  <!-- Header -->
  <div data-el="appHeader" style="display:flex; align-items:center; gap:9px; padding:14px 14px 12px; flex-shrink:0; border-bottom:1px solid #eef0f0;">
    <button class="hdr-back" title="Back to contents">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3a3a4a" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
    </button>
    <span style="flex:1; min-width:0; line-height:1.15;">
      <span style="display:block; font-size:13.5px; font-weight:700; color:#1a1a2e; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">Liens &amp; Encumbrances</span>
      <span style="display:block; font-size:10px; color:#b3b8bf;">Chapter 4 · Title &amp; Ownership</span>
    </span>
    <div style="display:flex; align-items:center; gap:7px; flex-shrink:0;">
      <div style="position:relative; flex-shrink:0;">
        <button data-el="langChip" title="Translation language" style="display:flex; align-items:center; gap:4px; border:1.5px solid #34D399; background:#34D399; color:#fff; font-family:inherit; font-size:11px; font-weight:700; padding:0 8px; height:28px; border-radius:999px; cursor:pointer; white-space:nowrap;">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><line x1="3" y1="12" x2="21" y2="12"></line><path d="M12 3a14 14 0 0 1 0 18a14 14 0 0 1 0-18z"></path></svg>
          <span data-el="langLabel">RU</span><span style="font-size:8px;">▾</span>
        </button>
        <div data-el="langMenu" style="display:none; position:absolute; top:calc(100% + 6px); right:0; background:#fff; border:1px solid #eef0f0; border-radius:13px; box-shadow:0 8px 26px rgba(26,26,46,.18); padding:5px; min-width:170px; max-height:420px; overflow-y:auto; z-index:60;"></div>
      </div>
      <button data-el="autoBtn" title="Listen / Read aloud" style="display:flex; align-items:center; justify-content:center; border:1.5px solid rgba(52,211,153,.55); background:#fff; color:#047857; font-family:inherit; width:28px; height:28px; border-radius:50%; cursor:pointer; padding:0; flex-shrink:0;">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="#047857"><polygon points="6 4 20 12 6 20 6 4"></polygon></svg>
      </button>
      <span style="width:1px; height:18px; background:#e3e7e9; flex-shrink:0;"></span>
      <button data-el="saveBtn" title="Bookmark page" style="display:flex; align-items:center; justify-content:center; border:none; background:none; cursor:pointer; width:26px; height:28px; padding:0; flex-shrink:0;">
        <svg data-el="bm" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#c9ced2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="transition:all .16s;"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path></svg>
      </button>
    </div>
  </div>

  <!-- Book page -->
  <div data-el="scrollArea" class="scroll" style="flex:1; min-height:0; overflow-y:auto; padding:18px 20px 14px;">

    <div style="font-size:10px; font-weight:800; letter-spacing:.12em; text-transform:uppercase; color:#34D399;">Chapter 4 · Section 2</div>
    <h1 data-el="tEN" style="margin:5px 0 2px; font-size:22px; font-weight:800; letter-spacing:-.02em; line-height:1.15;">Liens &amp; Encumbrances</h1>
    <div data-el="tTR" class="ru-line" style="font-size:12.5px; color:#a3a8af; margin-bottom:16px;"></div>

    <!-- Para 1 - definition -->
    <p data-el="p1EN" class="en">An <span class="tw" data-ru="p1-enc">encumbrance</span> is any <span class="tw" data-ru="p1-claim">claim</span>, charge, or <span class="tw" data-ru="p1-liab">liability</span> attached to real <span class="tw" data-ru="p1-prop">property</span> - a right held by someone who is not the owner. Every <span class="tw" data-ru="p1-lien">lien</span> is an encumbrance, but not every encumbrance is a lien.</p>
    <p data-el="p1TR" class="ru ru-line"></p>

    <!-- Subheading: two families -->
    <h2 data-el="h2EN" style="margin:22px 0 0; font-size:16px; font-weight:800; letter-spacing:-.01em;">Two families of encumbrances</h2>
    <div data-el="h2TR" class="ru-line" style="font-size:11.5px; color:#a3a8af; margin-bottom:10px;"></div>

    <!-- Figure 4.2 - taxonomy diagram -->
    <div style="background:#f9fbfa; border:1px solid #eef0f0; border-radius:14px; padding:13px 13px 12px;">
      <div style="text-align:center; margin-bottom:9px;">
        <span style="display:inline-block; background:#1a1a2e; color:#fff; font-size:10.5px; font-weight:700; padding:5px 14px; border-radius:8px;">Encumbrances</span>
      </div>
      <div style="display:flex; gap:9px;">
        <div style="flex:1;">
          <div style="background:rgba(52,211,153,.14); border:1px solid rgba(52,211,153,.4); border-radius:9px; padding:6px; text-align:center; font-size:10px; font-weight:800; color:#047857; margin-bottom:7px;">Financial · Liens</div>
          <div style="display:flex; flex-direction:column; gap:5px;">
            <div class="figchip">Mortgage<div class="figchip-tr ru-line" data-chip="mortgage"></div></div>
            <div class="figchip">Property tax<div class="figchip-tr ru-line" data-chip="propertyTax"></div></div>
            <div class="figchip">Mechanic’s<div class="figchip-tr ru-line" data-chip="mechanics"></div></div>
            <div class="figchip">Judgment<div class="figchip-tr ru-line" data-chip="judgment"></div></div>
          </div>
        </div>
        <div style="flex:1;">
          <div style="background:#eef0f2; border:1px solid #e0e4e6; border-radius:9px; padding:6px; text-align:center; font-size:10px; font-weight:800; color:#6b7280; margin-bottom:7px;">Non-financial</div>
          <div style="display:flex; flex-direction:column; gap:5px;">
            <div class="figchip">Easements<div class="figchip-tr ru-line" data-chip="easements"></div></div>
            <div class="figchip">Encroachments<div class="figchip-tr ru-line" data-chip="encroachments"></div></div>
            <div class="figchip">Deed restrictions<div class="figchip-tr ru-line" data-chip="deedRestrictions"></div></div>
          </div>
        </div>
      </div>
      <div data-el="figCap" class="ru-line" style="font-size:10.5px; color:#a3a8af; text-align:center; margin-top:10px; line-height:1.35;"></div>
    </div>

    <!-- Para 2 - split -->
    <p data-el="p2EN" class="en" style="margin-top:14px;">Encumbrances split into two groups. <span class="tw" data-ru="p2-fin">Financial</span> ones - <span class="tw" data-ru="p2-lien">liens</span> - secure a debt. Non-financial ones, like <span class="tw" data-ru="p2-ease">easements</span> and encroachments, limit how the land is used.</p>
    <p data-el="p2TR" class="ru ru-line"></p>

    <!-- Subheading: types of liens -->
    <h2 data-el="h3EN" style="margin:22px 0 0; font-size:16px; font-weight:800; letter-spacing:-.01em;">Types of liens</h2>
    <div data-el="h3TR" class="ru-line" style="font-size:11.5px; color:#a3a8af; margin-bottom:9px;"></div>

    <!-- Para 3 - lien definition -->
    <p data-el="p3EN" class="en">A <span class="tw" data-ru="p3-lien">lien</span> is a financial claim that secures the payment of a <span class="tw" data-ru="p3-debt">debt</span>. If the debt is not paid, the lien holder can force the property to be <span class="tw" data-ru="p3-sold">sold</span>. A lien is only a claim on value - it is not <span class="tw" data-ru="p3-own">ownership</span>.</p>
    <p data-el="p3TR" class="ru ru-line"></p>

    <!-- Para 4 - classifications -->
    <p data-el="p4EN" class="en" style="margin-top:14px;">Every lien is either <span class="tw" data-ru="p4-vol">voluntary</span> or <span class="tw" data-ru="p4-invol">involuntary</span>, and either <span class="tw" data-ru="p4-spec">specific</span> (one named property) or <span class="tw" data-ru="p4-gen">general</span> (all the owner’s property). A <span class="tw" data-ru="p4-mort">mortgage</span> is voluntary and specific; a property-tax lien is involuntary and specific; a <span class="tw" data-ru="p4-judg">judgment</span> lien is involuntary and general.</p>
    <p data-el="p4TR" class="ru ru-line"></p>

    <!-- Para 5 - priority & clearing -->
    <p data-el="p5EN" class="en" style="margin-top:14px;">When several liens exist, <span class="tw" data-ru="p5-prio">priority</span> usually follows “first in time, first in right” - the order they were recorded. The key exception: property-<span class="tw" data-ru="p5-tax">tax</span> liens are paid first, no matter when they were recorded. A lien must be <span class="tw" data-ru="p5-clear">cleared</span> before the property can be sold with clear <span class="tw" data-ru="p5-title">title</span>.</p>
    <p data-el="p5TR" class="ru ru-line"></p>

  </div>

  <!-- Footer: page nav -->
  <div data-el="bottomBar" style="flex-shrink:0; display:flex; align-items:center; justify-content:space-between; padding:11px 18px 15px; border-top:1px solid #f0f2f3; background:#fff;">
    <button class="nav-btn nav-back" title="Previous page">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
    </button>
    <span style="display:flex; flex-direction:column; align-items:center; line-height:1.15;">
      <span style="font-size:14px; font-weight:700; color:#6b7280; font-variant-numeric:tabular-nums; letter-spacing:.02em;">8 <span style="color:#c0c5c9; font-weight:600;">/ 42</span></span>
      <span style="font-size:9.5px; font-weight:600; color:#b3b8bf; letter-spacing:.02em;">Chapter 4</span>
    </span>
    <button class="nav-btn nav-next" title="Next page">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
    </button>
  </div>

  <!-- Floating word toolbar -->
  <div data-el="wbar" style="display:none; position:absolute; z-index:30; background:#fff; border-radius:12px; box-shadow:0 8px 24px rgba(26,26,46,.2); border:1px solid #eef0f0; padding:5px 6px; align-items:center; gap:3px;">
    <button class="wbtn" title="Pronounce">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3a3a4a" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" fill="#3a3a4a" stroke="none"></polygon><path d="M15.5 8.5a5 5 0 0 1 0 7"></path><path d="M19 5a10 10 0 0 1 0 14"></path></svg>
    </button>
    <span class="wsep"></span>
    <button data-el="addBtn" class="wbtn" title="Add to Dictionary" style="position:relative;">
      <span data-el="addPad" style="display:inline-flex; align-items:center; justify-content:center; padding:5px 7px; border-radius:8px; transition:background .18s;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path data-el="addBook" d="M5 5.5A1.5 1.5 0 0 1 6.5 4H18a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1H6.5A1.5 1.5 0 0 0 5 20.5z" stroke="#3a3a4a" stroke-width="1.8" stroke-linejoin="round"></path><path data-el="addSpine" d="M5 20.5A1.5 1.5 0 0 1 6.5 19H19" stroke="#3a3a4a" stroke-width="1.8" stroke-linejoin="round"></path><text data-el="addA" x="11.7" y="14.6" font-size="9" font-weight="800" text-anchor="middle" fill="#3a3a4a" font-family="Inter,sans-serif">A</text></svg>
      </span>
      <span data-el="addPip" style="position:absolute; top:1px; right:1px; width:13px; height:13px; border-radius:50%; display:flex; align-items:center; justify-content:center; background:#aab0b4; box-shadow:0 0 0 1.5px #fff;">
        <svg data-el="addPipIcon" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
      </span>
    </button>
    <span class="wsep"></span>
    <button class="wbtn" data-el="wcOpenBtn" title="Word card">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3a3a4a" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2.5"></rect><line x1="7" y1="9.5" x2="17" y2="9.5"></line><line x1="7" y1="13.5" x2="13" y2="13.5"></line></svg>
    </button>
    <span class="wsep"></span>
    <button class="wbtn" data-el="wbarCloseBtn" title="Close">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#aab0b4" stroke-width="2.2" stroke-linecap="round"><line x1="6" y1="6" x2="18" y2="18"></line><line x1="18" y1="6" x2="6" y2="18"></line></svg>
    </button>
    <span data-el="warrow" style="position:absolute; top:100%; left:50%; transform:translateX(-50%); width:0; height:0; border-left:6px solid transparent; border-right:6px solid transparent; border-top:6px solid #fff; filter:drop-shadow(0 2px 1px rgba(26,26,46,.08));"></span>
  </div>

  <!-- Toast -->
  <div data-el="toast" style="position:absolute; left:50%; bottom:64px; transform:translateX(-50%) translateY(12px); opacity:0; transition:all .28s; display:flex; align-items:center; gap:7px; padding:9px 15px; background:#1a1a2e; color:#fff; font-size:12px; font-weight:600; border-radius:22px; pointer-events:none; z-index:40; white-space:nowrap;">
    <span style="color:#34D399;">✓</span> Saved
  </div>

  <!-- Word card sheet -->
  <div data-el="wcScrim" style="display:none; position:absolute; inset:0; background:rgba(26,26,46,.28); z-index:50;"></div>
  <div data-el="wcSheet" style="position:absolute; left:0; right:0; top:600px; z-index:51; transition:top .32s cubic-bezier(.34,1.2,.5,1); background:#f3f5f7; border-radius:22px 22px 24px 24px; box-shadow:0 -8px 32px rgba(26,26,46,.18); padding:0 0 16px;">
    <div style="background:#fff; border-radius:22px; padding:16px 18px 16px; box-shadow:0 2px 10px rgba(26,26,46,.05);">
      <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:12px;">
        <div style="min-width:0;">
          <div data-el="wcWord" style="font-size:27px; font-weight:800; color:#1a1a2e; line-height:1.05;">lien</div>
          <div data-el="wcIpa" style="font-size:14px; color:#9aa1a0; margin-top:5px;">[liːn]</div>
        </div>
        <div style="display:flex; align-items:center; gap:8px; flex-shrink:0;">
          <button data-el="wcProBtn" title="Pronounce" style="border:none; background:#f4f6f7; border-radius:50%; width:38px; height:38px; cursor:pointer; display:flex; align-items:center; justify-content:center;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1a1a2e" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" fill="#1a1a2e" stroke="none"></polygon><path d="M15.5 8.5a5 5 0 0 1 0 7"></path><path d="M19 5a10 10 0 0 1 0 14"></path></svg>
          </button>
          <button data-el="wcCloseBtn" title="Close" style="border:none; background:#f4f6f7; border-radius:50%; width:38px; height:38px; cursor:pointer; display:flex; align-items:center; justify-content:center;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2.3" stroke-linecap="round"><line x1="6" y1="6" x2="18" y2="18"></line><line x1="18" y1="6" x2="6" y2="18"></line></svg>
          </button>
        </div>
      </div>

      <div data-el="wcPro" style="display:none; margin-top:14px;">
        <span style="display:inline-flex; align-items:center; gap:6px; font-size:10.5px; font-weight:800; letter-spacing:.04em; text-transform:uppercase; color:#047857; background:rgba(52,211,153,.14); border-radius:6px; padding:4px 10px 4px 8px;">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#047857" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
          Real Estate Concept
        </span>
        <div data-el="wcTr" style="font-size:18px; font-weight:600; color:#1a1a2e; margin-top:10px;"></div>
        <p data-el="wcDefEN" style="font-size:13.5px; color:#3a3a4a; line-height:1.5; margin:9px 0 0;"></p>
        <p data-el="wcDefRU" style="font-size:12px; color:#6b7280; line-height:1.45; margin:7px 0 0;"></p>
      </div>

      <div data-el="wcCommon" style="display:none; margin-top:12px;">
        <div data-el="wcMeanings" style="font-size:16px; color:#1a1a2e; line-height:1.7;"></div>
      </div>
    </div>

    <div style="padding:14px 18px 0;">
      <button data-el="wcAddBtn" style="width:100%; border:none; background:linear-gradient(135deg,#4ade80,#22c55e); color:#fff; font-family:inherit; font-size:15px; font-weight:700; padding:14px 8px; border-radius:14px; cursor:pointer; box-shadow:0 4px 16px rgba(52,211,153,.32); display:flex; align-items:center; justify-content:center; gap:8px;">Add &amp; learn</button>
    </div>
  </div>

</div>

<style is:global>
  [data-screen="textbook"] .tw { cursor: pointer; border-bottom: 1px dotted #c6cfcc; }
  [data-screen="textbook"] .hl { background: #d4f4e4; color: #047857; border-radius: 4px; padding: 0 1px; box-decoration-break: clone; -webkit-box-decoration-break: clone; border-bottom-color: transparent; }
  [data-screen="textbook"] .rw-on { background: #d4f4e4; color: #047857; border-radius: 4px; transition: background .08s; }
  [data-screen="textbook"] .nav-btn { width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: transform .08s ease, background .15s ease; flex-shrink: 0; }
  [data-screen="textbook"] .nav-btn:active { transform: scale(.9); }
  [data-screen="textbook"] .nav-back { border: 1.5px solid #d6dbe0; background: #fff; }
  [data-screen="textbook"] .nav-back:hover { background: #f5f7f9; }
  [data-screen="textbook"] .nav-next { border: none; background: #34D399; box-shadow: 0 4px 14px rgba(52,211,153,.32); }
  [data-screen="textbook"] .nav-next:hover { background: #2bc48a; }
  [data-screen="textbook"] .hdr-back { width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; border: none; background: #f4f6f7; flex-shrink: 0; transition: background .15s, transform .08s; padding: 0; }
  [data-screen="textbook"] .hdr-back:hover { background: #e9edee; }
  [data-screen="textbook"] .hdr-back:active { transform: scale(.9); }
  [data-screen="textbook"] .wbtn { display: flex; flex-direction: row; align-items: center; gap: 3px; border: none; background: none; cursor: pointer; font-family: inherit; padding: 4px 7px; border-radius: 8px; }
  [data-screen="textbook"] .wbtn:hover { background: #f5f7f9; }
  [data-screen="textbook"] .wbtn span { font-size: 11.5px; color: #3a3a4a; font-weight: 600; white-space: nowrap; }
  [data-screen="textbook"] .wsep { width: 1px; height: 16px; background: #eef0f0; flex-shrink: 0; }
  [data-screen="textbook"] .langOpt { display: flex; align-items: center; justify-content: space-between; gap: 10px; width: 100%; border: none; background: none; cursor: pointer; font-family: inherit; font-size: 12.5px; font-weight: 600; color: #1a1a2e; padding: 0 10px; min-height: 36px; line-height: 1.15; border-radius: 9px; text-align: left; }
  [data-screen="textbook"] .langOpt:hover { background: #f3f5f7; }
  [data-screen="textbook"] [data-el="langMenu"]::-webkit-scrollbar { width: 0; }
  [data-screen="textbook"] p.en { margin: 0; font-size: 15px; line-height: 1.62; color: #2b2f3a; }
  [data-screen="textbook"] p.ru { margin: 5px 0 0; font-size: 12px; line-height: 1.5; color: #a3a8af; }
  [data-screen="textbook"] .scroll::-webkit-scrollbar { width: 0; }
  [data-screen="textbook"] .figchip { background: #fff; border: 1px solid #e6e9ea; border-radius: 7px; padding: 5px 7px; font-size: 10px; font-weight: 600; color: #3a3a4a; text-align: center; }
  [data-screen="textbook"] .figchip-tr { font-size: 8.5px; font-weight: 600; color: #a3a8af; margin-top: 2px; line-height: 1.2; }
</style>

<script>
  function initTextbook(root: HTMLElement) {
    // ════════════ Language model ════════════
    var LMETA: Record<string, { label: string; native: string; tts: string; dir: string }> = {
