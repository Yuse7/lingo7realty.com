      if (addedWords[cardKey]) {
        b.style.background = '#fff'; b.style.color = '#047857'; b.style.border = '1.5px solid #34D399'; b.style.boxShadow = 'none';
        b.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#34D399" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> In dictionary';
      } else {
        b.style.background = 'linear-gradient(135deg,#4ade80,#22c55e)'; b.style.color = '#fff'; b.style.border = 'none'; b.style.boxShadow = '0 4px 16px rgba(52,211,153,.32)';
        b.innerHTML = 'Add &amp; learn';
      }
    }
    function cardAdd(ev?: Event) {
      if (ev) { ev.stopPropagation(); }
      if (!cardKey) { return; }
      var nowOn = !addedWords[cardKey];
      if (nowOn) { addedWords[cardKey] = true; } else { delete addedWords[cardKey]; }
      syncCardBtn();
      if (nowOn) { showToast(); }
    }
    function openWordCard(ev?: Event) {
      if (ev) { ev.stopPropagation(); }
      var raw = currentWord ? currentWord.textContent!.trim() : 'lien';
      var key = raw.toLowerCase().replace(/[^a-z]/g, '');
      // plural → singular fallback (easements → easement, liens → lien)
      if (!DICT[key] && key.length > 3 && key.charAt(key.length - 1) === 's' && DICT[key.slice(0, -1)]) { key = key.slice(0, -1); }
      cardKey = key;
      var d = DICT[key] || { type: 'common', ipa: '' };
      var lc = CARD[curLang] || CARD.ru;
      var dir = LMETA[curLang].dir;
      var wcWord = q('wcWord'); if (wcWord) { wcWord.textContent = d.lemma || key; }
      var wcIpa = q('wcIpa'); if (wcIpa) { wcIpa.textContent = d.ipa || ''; }
      var pro = q('wcPro'), common = q('wcCommon');
      if (d.type === 'pro') {
        if (pro) { pro.style.display = 'block'; } if (common) { common.style.display = 'none'; }
        var pdata = (lc.pro && lc.pro[key]) ? lc.pro[key] : { tr: '', def: '' };
        var tr = q('wcTr');
        if (tr) { tr.textContent = '- ' + (pdata.tr || ''); tr.setAttribute('dir', dir); }
        var defEN = q('wcDefEN'); if (defEN) { defEN.textContent = EN_DEF[key] || ''; }
        var dru = q('wcDefRU');
        if (dru) { dru.textContent = pdata.def || ''; dru.setAttribute('dir', dir); }
        setCardRu(false);
      } else {
        if (common) { common.style.display = 'block'; } if (pro) { pro.style.display = 'none'; }
        var raw2 = (lc.common && lc.common[key]) ? lc.common[key] : (d.lemma || key);
        var list = raw2.split(';').map(function (s) { return s.trim(); }).filter(Boolean);
        var mEl = q('wcMeanings');
        if (mEl) {
          mEl.setAttribute('dir', dir);
          mEl.innerHTML = list.map(function (m) {
            return '<div style="display:flex; gap:7px;"><span style="color:#9aa1a0;">-</span><span>' + esc(m) + '</span></div>';
          }).join('');
        }
      }
      syncCardBtn();
      var wb = q('wbar'); if (wb) { wb.style.display = 'none'; }
      var scrim = q('wcScrim'); if (scrim) { scrim.style.display = 'block'; }
      requestAnimationFrame(positionSheet);
    }
    function closeWordCard(ev?: Event) {
      if (ev) { ev.stopPropagation(); }
      var sheet = q('wcSheet'); if (sheet) { sheet.style.top = CARD_EL.clientHeight + 'px'; }
      var scrim = q('wcScrim'); if (scrim) { scrim.style.display = 'none'; }
      clearHl();
    }

    // ════════════ Tap a word ════════════
    var currentWord: HTMLElement | null = null;
    function tapWord(ev: Event, el: HTMLElement) {
      ev.stopPropagation();
      currentWord = el;
      var anchor = el.getAttribute('data-ru');
      var ru = (anchor && parallelOn) ? (root.querySelector('[data-el="' + anchor + '"]') as HTMLElement | null) : null;
      var bar = q('wbar');
      if (!bar) { return; }
      if (el.classList.contains('hl')) { clearHl(); bar.style.display = 'none'; return; }
      clearHl();
      el.classList.add('hl');
      if (ru) { ru.classList.add('hl'); }
      syncAddBtn();
      bar.style.visibility = 'hidden'; bar.style.display = 'flex';
      var cr = CARD_EL.getBoundingClientRect();
      var wr = el.getBoundingClientRect();
      var bw = bar.offsetWidth, bh = bar.offsetHeight;
      var wcx = wr.left - cr.left + wr.width / 2;
      var arrow = q('warrow');
      var top = wr.top - cr.top - bh - 9;
      if (top < 8) { top = 8; }
      var left = Math.max(8, Math.min(wcx - bw / 2, CARD_EL.clientWidth - bw - 8));
      bar.style.left = left + 'px'; bar.style.top = top + 'px';
      if (arrow) { arrow.style.left = (wcx - left) + 'px'; }
      bar.style.visibility = 'visible';
    }
    function closeBar(ev?: Event) { if (ev) { ev.stopPropagation(); } clearHl(); var wb = q('wbar'); if (wb) { wb.style.display = 'none'; } }
    function syncAddBtn() {
      var w = currentWord ? currentWord.textContent!.trim().toLowerCase().replace(/[^a-z]/g, '') : '';
      var on = !!addedWords[w];
      var book = q('addBook'), spine = q('addSpine'), letter = q('addA');
      var pad = q('addPad'), pip = q('addPip'), pipIcon = q('addPipIcon');
      if (on) {
        if (book) { book.setAttribute('fill', '#34D399'); book.setAttribute('stroke', '#34D399'); } if (spine) { spine.setAttribute('stroke', '#ffffff'); } if (letter) { letter.setAttribute('fill', '#ffffff'); }
        if (pad) { pad.style.background = 'rgba(52,211,153,.14)'; } if (pip) { pip.style.background = '#34D399'; }
        if (pipIcon) { pipIcon.innerHTML = '<polyline points="20 6 9 17 4 12"></polyline>'; }
      } else {
        if (book) { book.setAttribute('fill', 'none'); book.setAttribute('stroke', '#3a3a4a'); } if (spine) { spine.setAttribute('stroke', '#3a3a4a'); } if (letter) { letter.setAttribute('fill', '#3a3a4a'); }
        if (pad) { pad.style.background = 'transparent'; } if (pip) { pip.style.background = '#aab0b4'; }
        if (pipIcon) { pipIcon.innerHTML = '<line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line>'; }
      }
    }
    function showToast() {
      var t = q('toast');
      if (!t) { return; }
      t.style.opacity = '1'; t.style.transform = 'translateX(-50%) translateY(0)';
      setTimeout(function () { t.style.opacity = '0'; t.style.transform = 'translateX(-50%) translateY(12px)'; }, 1400);
    }
    function addWord(ev: Event) {
      ev.stopPropagation();
      var w = currentWord ? currentWord.textContent!.trim().toLowerCase().replace(/[^a-z]/g, '') : '';
      if (!w) { return; }
      var nowOn = !addedWords[w];
      if (nowOn) { addedWords[w] = true; } else { delete addedWords[w]; }
      syncAddBtn();
      if (nowOn) { showToast(); }
    }
    document.addEventListener('click', function () {
      if (!autoOn) { closeBar(); }
      var menu = q('langMenu'); if (menu) { menu.style.display = 'none'; }
    });

    // ════════════ Bookmark ════════════
    var saved = false;
    function toggleSave(ev?: Event) {
      if (ev) { ev.stopPropagation(); }
      saved = !saved;
      var bm = q('bm');
      if (!bm) { return; }
      bm.setAttribute('fill', saved ? '#34D399' : 'none');
      bm.setAttribute('stroke', saved ? '#34D399' : '#c9ced2');
      bm.style.transform = 'scale(1.2)';
      setTimeout(function () { bm.style.transform = 'scale(1)'; }, 160);
    }

    // ════════════ Auto read-aloud ════════════
    var autoOn = false, autoTimer: ReturnType<typeof setTimeout> | null = null;
    var autoSteps: { el: HTMLElement | null; say: string; lang: string }[] = [], autoIdx = -1;
    var LETTER = /[A-Za-zА-Яа-яЁё؀-ۿ一-鿿]/;
    function setAutoBtn(on: boolean) {
      var b = q('autoBtn');
      if (!b) { return; }
      if (on) { b.style.background = '#34D399'; b.style.borderColor = '#34D399';
        b.innerHTML = '<svg width="11" height="11" viewBox="0 0 24 24" fill="#fff"><rect x="6" y="5" width="4" height="14" rx="1"></rect><rect x="14" y="5" width="4" height="14" rx="1"></rect></svg>'; }
      else { b.style.background = '#fff'; b.style.borderColor = 'rgba(52,211,153,.55)';
        b.innerHTML = '<svg width="11" height="11" viewBox="0 0 24 24" fill="#047857"><polygon points="6 4 20 12 6 20 6 4"></polygon></svg>'; }
    }
    function speak(text: string, lang: string) {
      if (!window.speechSynthesis) { return; }
      try { window.speechSynthesis.cancel();
        var u = new SpeechSynthesisUtterance(text); u.lang = lang; u.rate = (lang === 'en-US') ? 0.85 : 0.95;
        window.speechSynthesis.speak(u);
      } catch (e) {}
    }
    var EN_SAY: Record<string, string> = {
      p1: 'An encumbrance is any claim, charge, or liability attached to real property - a right held by someone who is not the owner. Every lien is an encumbrance, but not every encumbrance is a lien.',
      p2: 'Encumbrances split into two groups. Financial ones - liens - secure a debt. Non-financial ones, like easements and encroachments, limit how the land is used.',
      p3: 'A lien is a financial claim that secures the payment of a debt. If the debt is not paid, the lien holder can force the property to be sold. A lien is only a claim on value - it is not ownership.',
      p4: 'Every lien is either voluntary or involuntary, and either specific - one named property - or general - all the owner\'s property. A mortgage is voluntary and specific; a property tax lien is involuntary and specific; a judgment lien is involuntary and general.',
      p5: 'When several liens exist, priority usually follows first in time, first in right - the order they were recorded. The key exception: property tax liens are paid first, no matter when they were recorded. A lien must be cleared before the property can be sold with clear title.'
    };
    function buildSteps() {
      var tl = LMETA[curLang].tts;
      var steps: { el: HTMLElement | null; say: string; lang: string }[] = [];
      (['p1', 'p2', 'p3', 'p4', 'p5'] as const).forEach(function (k) {
        steps.push({ el: q(k + 'EN'), say: EN_SAY[k], lang: 'en-US' });
        if (parallelOn) { steps.push({ el: q(k + 'TR'), say: plainSegs(I18N[curLang][k]), lang: tl }); }
      });
      return steps;
    }
    function startAuto() {
      autoOn = true; setAutoBtn(true);
      var wb = q('wbar'); if (wb) { wb.style.display = 'none'; }
      autoSteps = buildSteps(); autoIdx = -1; autoStep();
    }
    function stopAuto() {
      autoOn = false; if (autoTimer) { clearTimeout(autoTimer); } clearHl();
      if (window.speechSynthesis) { try { window.speechSynthesis.cancel(); } catch (e) {} }
      setAutoBtn(false);
    }
    function autoStep() {
      if (!autoOn) { return; }
      clearHl(); autoIdx++;
      if (autoIdx >= autoSteps.length) { stopAuto(); return; }
      runStep(autoSteps[autoIdx]);
    }
    function wordSpansOf(el: HTMLElement) {
      if (!el.getAttribute('data-rw')) {
        Array.prototype.slice.call(el.childNodes).forEach(function (n: ChildNode) {
          if (n.nodeType === 3 && LETTER.test(n.nodeValue || '')) {
            var frag = document.createDocumentFragment();
            (n.nodeValue || '').split(/(\s+)/).forEach(function (tok) {
              if (LETTER.test(tok)) { var s = document.createElement('span'); s.className = 'rw'; s.textContent = tok; frag.appendChild(s); }
              else { frag.appendChild(document.createTextNode(tok)); }
            });
            el.replaceChild(frag, n);
          }
        });
        el.setAttribute('data-rw', '1');
      }
      return Array.prototype.slice.call(el.querySelectorAll('span')).filter(function (e: HTMLElement) {
        return !e.querySelector('span') && LETTER.test(e.textContent || '');
      });
    }
    function runStep(s: { el: HTMLElement | null; say: string; lang: string }) {
      if (s.el) {
        var sa = q('scrollArea');
        if (sa) {
          var er = s.el.getBoundingClientRect(), sr = sa.getBoundingClientRect();
          if (er.top < sr.top + 20 || er.bottom > sr.bottom - 20) { sa.scrollTop += (er.top - sr.top) - 40; }
        }
      }
      var spans = wordSpansOf(s.el!);
      speak(s.say, s.lang);
      var total = 480 + 42 * s.say.length;
      var per = Math.max(150, total / Math.max(1, spans.length));
      var i = -1;
      function adv() {
        if (!autoOn) { return; }
        if (i >= 0 && spans[i]) { spans[i].classList.remove('rw-on'); }
        i++;
        if (i >= spans.length) { autoTimer = setTimeout(autoStep, 260); return; }
        spans[i].classList.add('rw-on');
        autoTimer = setTimeout(adv, per);
      }
      adv();
    }
    function toggleAuto(ev: Event) { ev.stopPropagation(); if (autoOn) { stopAuto(); } else { startAuto(); } }

    // ════════════ Make every English word tappable ════════════
    function enableAllWords(name: string) {
      var p = q(name);
      if (!p) { return; }
      Array.prototype.slice.call(p.childNodes).forEach(function (node: ChildNode) {
        if (node.nodeType !== 3) { return; }
        var frag = document.createDocumentFragment();
        (node.nodeValue || '').split(/(\s+)/).forEach(function (tok) {
          var core = /[A-Za-z]/.test(tok) ? tok.match(/^([^A-Za-z]*)([A-Za-z][A-Za-z'’-]*)([^A-Za-z]*)$/) : null;
          if (core) {
            if (core[1]) { frag.appendChild(document.createTextNode(core[1])); }
            var s = document.createElement('span'); s.className = 'tw'; s.textContent = core[2]; s.onclick = function (e) { tapWord(e, s); };
            frag.appendChild(s);
            if (core[3]) { frag.appendChild(document.createTextNode(core[3])); }
          } else { frag.appendChild(document.createTextNode(tok)); }
        });
        p!.replaceChild(frag, node);
      });
    }

    // ════════════ Wire events (former inline on* handlers) ════════════
    root.querySelectorAll<HTMLElement>('.tw[data-ru]').forEach(function (el) {
      el.addEventListener('click', function (e) { tapWord(e, el); });
    });
    var hdrBack = root.querySelector('.hdr-back'); if (hdrBack) { hdrBack.addEventListener('click', function (e) { e.stopPropagation(); }); }
    root.querySelectorAll('.nav-btn').forEach(function (b) { b.addEventListener('click', function (e) { e.stopPropagation(); }); });
    var langChip = q('langChip'); if (langChip) { langChip.addEventListener('click', toggleLangMenu); }
    var langMenu = q('langMenu'); if (langMenu) { langMenu.addEventListener('click', function (e) { e.stopPropagation(); }); }
    var autoBtn = q('autoBtn'); if (autoBtn) { autoBtn.addEventListener('click', toggleAuto); }
    var saveBtn = q('saveBtn'); if (saveBtn) { saveBtn.addEventListener('click', toggleSave); }
    var addBtn = q('addBtn'); if (addBtn) { addBtn.addEventListener('click', addWord); }
    var wcOpenBtn = q('wcOpenBtn'); if (wcOpenBtn) { wcOpenBtn.addEventListener('click', openWordCard); }
    var wbarCloseBtn = q('wbarCloseBtn'); if (wbarCloseBtn) { wbarCloseBtn.addEventListener('click', closeBar); }
    // pronounce buttons in wbar + word card sheet (originally onclick="event.stopPropagation()")
    var wbarPron = root.querySelector('[data-el="wbar"] .wbtn[title="Pronounce"]'); if (wbarPron) { wbarPron.addEventListener('click', function (e) { e.stopPropagation(); }); }
    var wcProBtn = q('wcProBtn'); if (wcProBtn) { wcProBtn.addEventListener('click', function (e) { e.stopPropagation(); }); }
    var wcScrim = q('wcScrim'); if (wcScrim) { wcScrim.addEventListener('click', closeWordCard); }
    var wcCloseBtn = q('wcCloseBtn'); if (wcCloseBtn) { wcCloseBtn.addEventListener('click', closeWordCard); }
    var wcAddBtn = q('wcAddBtn'); if (wcAddBtn) { wcAddBtn.addEventListener('click', cardAdd); }

    (['p1EN', 'p2EN', 'p3EN', 'p4EN', 'p5EN']).forEach(enableAllWords);

    // init
    applyLang();

    // ════════════ Авто-демо (demo prop): экран некликабельный, «палец» проигрывает сценарий по циклу ════════════
    (function () {
      if (root.dataset.demo !== '1') { return; }
      var stage = CARD_EL;
      stage.style.pointerEvents = 'none';                 // глушим пользовательское взаимодействие
      var sa = q('scrollArea');
      if (!sa) { return; }

      var dot = document.createElement('div');
      dot.setAttribute('aria-hidden', 'true');
      dot.style.cssText = 'position:absolute; left:-60px; top:-60px; width:24px; height:24px; border-radius:50%; background:rgba(26,26,46,.5); border:2.5px solid #fff; box-shadow:0 3px 10px rgba(0,0,0,.3); z-index:90; pointer-events:none; opacity:0; transition:left .6s cubic-bezier(.45,.05,.25,1), top .6s cubic-bezier(.45,.05,.25,1), opacity .3s, transform .14s ease;';
      stage.appendChild(dot);

      function sleep(ms: number) { return new Promise<void>(function (r) { setTimeout(r, ms); }); }
      function ev() { return { stopPropagation: function () {} } as unknown as Event; }
      function posOf(el: HTMLElement) {
        var cr = stage.getBoundingClientRect(), r = el.getBoundingClientRect();
        return { x: r.left - cr.left + r.width / 2, y: r.top - cr.top + r.height / 2 };
      }
      function moveTo(el: HTMLElement | null) {
        if (!el) { return sleep(0); }
        var p = posOf(el);
        dot.style.opacity = '1';
        dot.style.left = (p.x - 12) + 'px';
        dot.style.top = (p.y - 12) + 'px';
        return sleep(700);
      }
      function ripple() {
        var x = parseFloat(dot.style.left) + 12, y = parseFloat(dot.style.top) + 12;
        var r = document.createElement('div');
        r.style.cssText = 'position:absolute; left:' + (x - 11) + 'px; top:' + (y - 11) + 'px; width:22px; height:22px; border-radius:50%; border:2px solid rgba(52,211,153,.9); z-index:89; pointer-events:none; opacity:.9; transform:scale(.4); transition:transform .5s ease-out, opacity .5s ease-out;';
        stage.appendChild(r);
        requestAnimationFrame(function () { r.style.transform = 'scale(2.6)'; r.style.opacity = '0'; });
        setTimeout(function () { r.remove(); }, 540);
      }
      function tap() {
        dot.style.transform = 'scale(.72)';
        ripple();
        return sleep(160).then(function () { dot.style.transform = 'scale(1)'; return sleep(160); });
      }
      function smoothScroll(to: number, dur: number) {
        return new Promise<void>(function (res) {
          var from = sa!.scrollTop, d = to - from, t0: number | null = null;
          if (Math.abs(d) < 1) { return res(); }
          function step(ts: number) {
            if (t0 === null) { t0 = ts; }
            var p = Math.min(1, (ts - t0) / dur);
            var e = p < .5 ? 2 * p * p : 1 - Math.pow(-2 * p + 2, 2) / 2;
            sa!.scrollTop = from + d * e;
            if (p < 1) { requestAnimationFrame(step); } else { res(); }
          }
          requestAnimationFrame(step);
        });
      }
      function reset() {
        try { closeWordCard(ev()); } catch (e) {}
        try { closeBar(ev()); } catch (e) {}
        try { addedWords = {}; } catch (e) {}
        try { if (saved) { toggleSave(ev()); } } catch (e) {}
        sa!.scrollTop = 0;
      }
      var firstWord = root.querySelector('.tw[data-ru="p1-enc"]') as HTMLElement | null;

      function cycle() {
        reset();
        dot.style.opacity = '0';
        return sleep(800)
          .then(function () { return moveTo(firstWord); })
          .then(tap)
          .then(function () { if (firstWord) { tapWord(ev(), firstWord); } return sleep(720); })
          .then(function () { return moveTo(q('wcOpenBtn')); })
          .then(tap)
          .then(function () { openWordCard(ev()); return sleep(820); })
          .then(function () { return moveTo(q('wcAddBtn')); })
          .then(tap)
          .then(function () { cardAdd(ev()); return sleep(1250); })
          .then(function () { return moveTo(q('wcCloseBtn')); })
          .then(tap)
          .then(function () { closeWordCard(ev()); return sleep(720); })
          .then(function () { dot.style.opacity = '0'; return smoothScroll(Math.min(sa!.scrollHeight - sa!.clientHeight, 300), 1000); })
          .then(function () { return sleep(560); })
          .then(function () { return moveTo(q('saveBtn')); })
          .then(tap)
          .then(function () { toggleSave(ev()); return sleep(1350); })
          .then(function () { dot.style.opacity = '0'; return sleep(850); });
      }
      var running = false;
      function loop() { if (!running) { return; } cycle().then(function () { if (running) { loop(); } }); }
      // play/pause come from the page as CustomEvents on root (was window postMessage __l7:'libdemo')
      root.addEventListener('l7:play', function () { if (!running) { running = true; loop(); } });
      root.addEventListener('l7:pause', function () { running = false; });
    })();
  }

  document.querySelectorAll<HTMLElement>('[data-screen="textbook"]').forEach(initTextbook);
</script>
