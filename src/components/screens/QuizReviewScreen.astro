        deed: { tr: 'سند ملكية', def: 'سند الملكية وثيقة قانونية تنقل ملكية العقار من البائع إلى المشتري.' },
        closing: { tr: 'إغلاق الصفقة', def: 'الإغلاق هو الخطوة الأخيرة في الصفقة، حيث تُوقَّع المستندات وتُنقَل الملكية وتُسوَّى المدفوعات.' }
      }, common: {
        property: 'ملكية؛ عقار؛ خاصية', legal: 'قانوني؛ شرعي', claim: 'مطالبة؛ دعوى؛ ادعاء', debt: 'دين؛ مديونية', paid: 'يدفع؛ يسدد', sold: 'يبيع', cleared: 'يزيل؛ يسدد', stays: 'يبقى؛ يظل', against: 'ضد؛ على؛ مقابل', until: 'حتى', when: 'عندما', called: 'يسمى؛ يدعى', with: 'مع؛ بواسطة'
      } },
      tl: { pro: {
        lien: { tr: 'lien (pananagutan sa ari-arian)', def: 'Ang lien ay legal na karapatan ng pinagkakautangan na hawakan ang ari-arian ng may utang hanggang mabayaran ito; dapat itong maalis kapag naibenta ang ari-arian.' },
        easement: { tr: 'easement (karapatang gamitin)', def: 'Ang easement ay karapatang gamitin ang lupa ng iba para sa tiyak na layunin, gaya ng daanan o utilidad, nang hindi ito pag-aari.' },
        encumbrance: { tr: 'encumbrance (pasanin)', def: 'Ang encumbrance ay anumang karapatan o paghahabol ng ikatlong partido sa ari-arian na naglilimita sa paggamit o pagbebenta nito.' },
        deed: { tr: 'titulo / kasulatan', def: 'Ang deed ay legal na dokumento na naglilipat ng pagmamay-ari ng ari-arian mula sa nagbebenta patungo sa bumibili.' },
        closing: { tr: 'closing (pagtatapos)', def: 'Ang closing ay ang huling hakbang ng transaksiyon, kung saan pinipirmahan ang mga dokumento, inililipat ang pagmamay-ari, at inaayos ang mga bayad.' }
      }, common: {
        property: 'ari-arian; pag-aari; katangian', legal: 'legal; ayon sa batas', claim: 'paghahabol; karapatan; angkin', debt: 'utang', paid: 'magbayad', sold: 'magbenta', cleared: 'alisin; bayaran nang lubos', stays: 'manatili', against: 'laban sa; sa', until: 'hanggang', when: 'kapag; kailan', called: 'tawagin', with: 'kasama; gamit'
      } }
    };

    // ════════════ State (per-instance) ════════════
    var curLang = 'ru';        // active translation language (for card + lines)
    var parallelOn = true;     // are parallel lines shown
    var CARD_EL = root;        // the phone frame (was div[style*="600px"])

    // root-scoped query helper (replaces document.getElementById; never global)
    function q(name: string) { return root.querySelector('[data-el="' + name + '"]') as HTMLElement | null; }

    function esc(t: string) { return String(t).replace(/&/g, '&amp;').replace(/</g, '&lt;'); }
    function renderSegs(arr: Seg[]) {
      return arr.map(function (s) {
        return typeof s === 'string' ? esc(s) : '<span data-el="' + s[0] + '">' + esc(s[1]) + '</span>';
      }).join('');
    }
    function plainSegs(arr: Seg[]) {
      return arr.map(function (s) { return typeof s === 'string' ? s : s[1]; }).join('');
    }

    function clearHl() {
      root.querySelectorAll('.hl').forEach(function (e) { e.classList.remove('hl'); });
      root.querySelectorAll('.rw-on').forEach(function (e) { e.classList.remove('rw-on'); });
      root.querySelectorAll('.read-opt').forEach(function (e) { e.classList.remove('read-opt'); });
    }

    // ════════════ Language application ════════════
    function applyLang() {
      var L = I18N[curLang], dir = LMETA[curLang].dir;
      var lb = q('lngBadge'); if (lb) { lb.textContent = LMETA[curLang].label; }
      var qt = q('qTrans');
      if (qt) { qt.innerHTML = renderSegs(L.q); qt.setAttribute('dir', dir); }
      var xt = q('exTrans');
      if (xt) { xt.innerHTML = renderSegs(L.ex); xt.setAttribute('dir', dir); }
      for (var i = 0; i < 4; i++) {
        var opt = q('opt' + i);
        var o = opt ? opt.querySelector('.opt-ru') as HTMLElement | null : null;
        if (o) { o.textContent = L.opt[i]; o.setAttribute('dir', dir); }
      }
      root.querySelectorAll<HTMLElement>('.ru-line').forEach(function (e) { e.style.display = parallelOn ? '' : 'none'; });
    }

    function buildLangMenu() {
      var menu = q('langMenu'); if (!menu) { return; }
      menu.innerHTML = '';
      LANG_ORDER.forEach(function (code) {
        var m = LMETA[code];
        var b = document.createElement('button');
        b.className = 'langOpt';
        if (code === 'ar') { b.setAttribute('dir', 'rtl'); }
        var active = (code === 'off') ? !parallelOn : (parallelOn && curLang === code);
        b.innerHTML = '<span>' + m.native + '</span><span class="langTick" style="color:#34D399; font-weight:800; display:' + (active ? 'inline' : 'none') + ';">✓</span>';
        b.onclick = function (e) { e.stopPropagation(); pickLang(code); };
        menu!.appendChild(b);
      });
    }
    function toggleLangMenu(e: Event) {
      e.stopPropagation();
      var m = q('langMenu'); if (!m) { return; }
      if (m.style.display === 'block') { m.style.display = 'none'; return; }
      buildLangMenu();
      m.style.display = 'block';
    }
    function pickLang(code: string) {
      if (code === 'off') { parallelOn = false; }
      else { parallelOn = true; curLang = code; }
      applyLang();
      var chip = q('langChip');
      var ll = q('langLabel'); if (ll) { ll.textContent = parallelOn ? LMETA[curLang].label : 'Translate'; }
      if (chip) {
        if (parallelOn) { chip.style.background = '#34D399'; chip.style.color = '#fff'; chip.style.borderColor = '#34D399'; }
        else { chip.style.background = '#fff'; chip.style.color = '#047857'; chip.style.borderColor = 'rgba(52,211,153,.55)'; }
      }
      if (!parallelOn) { clearHl(); var wb = q('wbar'); if (wb) { wb.style.display = 'none'; } }
      var lm = q('langMenu'); if (lm) { lm.style.display = 'none'; }
    }

    // ════════════ Answer reveal ════════════
    var CORRECT = 1, answered = false, currentWord: HTMLElement | null = null;
    function markOpt(i: number, kind: string) {
      var el = q('opt' + i); if (!el) { return; }
      var badge = el.querySelector('.opt-badge') as HTMLElement | null;
      var en = el.querySelector('.opt-en') as HTMLElement | null;
      var ru = el.querySelector('.opt-ru') as HTMLElement | null;
      if (kind === 'correct') {
        el.style.border = '2px solid #34D399'; el.style.background = 'rgba(52,211,153,.1)';
        if (en) { en.style.fontWeight = '700'; } if (ru) { ru.style.color = '#059669'; }
        if (badge) { badge.style.background = '#34D399'; badge.textContent = '✓'; badge.style.display = 'flex'; }
      } else if (kind === 'wrong') {
        el.style.border = '2px solid #d05656'; el.style.background = '#fdecec';
        if (en) { en.style.fontWeight = '600'; }
        if (badge) { badge.style.background = '#d05656'; badge.textContent = '✕'; badge.style.display = 'flex'; }
      }
    }
    function revealAnswer(chosen: number | null) {
      answered = true;
      markOpt(CORRECT, 'correct');
      if (chosen !== null && chosen !== CORRECT) { markOpt(chosen, 'wrong'); }
      var ex = q('exBox'); if (ex) { ex.style.display = 'block'; }
      if (!autoOn) { var bb = q('bottomBar'); if (bb) { bb.style.display = 'flex'; } }
    }
    function pickAnswer(i: number) { if (answered || autoOn) { return; } revealAnswer(i); }

    // ════════════ Word card ════════════
    var cardRuOn = false, cardKey = '', addedWords: Record<string, boolean> = {};
    function positionSheet() {
      var sheet = q('wcSheet'); if (!sheet) { return; }
      sheet.style.top = (CARD_EL.clientHeight - sheet.offsetHeight) + 'px';
    }
    function setCardRu(on: boolean) {
      cardRuOn = on;
      var dru = q('wcDefRU'); if (dru) { dru.style.display = 'block'; }
      positionSheet();
    }
    function toggleCardRu(ev?: Event) { if (ev) { ev.stopPropagation(); } setCardRu(!cardRuOn); }

    function syncCardBtn() {
      var b = q('wcAddBtn');
      if (!b) { return; }
      if (addedWords[cardKey]) {
        b.style.background = '#fff'; b.style.color = '#047857'; b.style.border = '1.5px solid #34D399'; b.style.boxShadow = 'none';
        b.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#34D399" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> In dictionary';
      } else {
        b.style.background = 'linear-gradient(135deg,#4ade80,#22c55e)'; b.style.color = '#fff'; b.style.border = 'none'; b.style.boxShadow = '0 4px 16px rgba(52,211,153,.32)';
        b.innerHTML = 'Add &amp; learn';
      }
    }
    function cardAdd(ev?: Event) {
      if (ev) { ev.stopPropagation(); }
      if (!cardKey) { return; }
      var nowOn = !addedWords[cardKey];
      if (nowOn) { addedWords[cardKey] = true; } else { delete addedWords[cardKey]; }
      syncCardBtn();
      if (nowOn) { showToast(); }
    }
    function openWordCard(ev?: Event) {
      if (ev) { ev.stopPropagation(); }
      var raw = currentWord ? (currentWord.textContent || '').trim() : 'lien';
      var key = raw.toLowerCase().replace(/[^a-z]/g, '');
      cardKey = key;
      var d = DICT[key] || { type: 'common', ipa: '' };
      var lc = CARD[curLang] || CARD.ru;
      var dir = LMETA[curLang].dir;
      var wcWord = q('wcWord'); if (wcWord) { wcWord.textContent = d.lemma || key; }
      var wcIpa = q('wcIpa'); if (wcIpa) { wcIpa.textContent = d.ipa || ''; }
      var pro = q('wcPro'), common = q('wcCommon');
      if (d.type === 'pro') {
        if (pro) { pro.style.display = 'block'; } if (common) { common.style.display = 'none'; }
        var pdata = (lc.pro && lc.pro[key]) ? lc.pro[key] : { tr: '', def: '' };
        var tr = q('wcTr');
        if (tr) { tr.textContent = '- ' + (pdata.tr || ''); tr.setAttribute('dir', dir); }
        var den = q('wcDefEN'); if (den) { den.textContent = EN_DEF[key] || ''; }
        var dru = q('wcDefRU');
        if (dru) { dru.textContent = pdata.def || ''; dru.setAttribute('dir', dir); }
        setCardRu(true);
      } else {
        if (common) { common.style.display = 'block'; } if (pro) { pro.style.display = 'none'; }
        var raw2 = (lc.common && lc.common[key]) ? lc.common[key] : (d.lemma || key);
        var list = raw2.split(';').map(function (s) { return s.trim(); }).filter(Boolean);
        var mEl = q('wcMeanings');
        if (mEl) {
          mEl.setAttribute('dir', dir);
          mEl.innerHTML = list.map(function (m) {
            return '<div style="display:flex; gap:7px;"><span style="color:#9aa1a0;">-</span><span>' + esc(m) + '</span></div>';
          }).join('');
        }
      }
      syncCardBtn();
      var wb = q('wbar'); if (wb) { wb.style.display = 'none'; }
      var scrim = q('wcScrim'); if (scrim) { scrim.style.display = 'block'; }
      requestAnimationFrame(positionSheet);
    }
    function closeWordCard(ev?: Event) {
      if (ev) { ev.stopPropagation(); }
      var sheet = q('wcSheet'); if (sheet) { sheet.style.top = CARD_EL.clientHeight + 'px'; }
      var scrim = q('wcScrim'); if (scrim) { scrim.style.display = 'none'; }
      clearHl();
    }

    // ════════════ Tap a word ════════════
    function tapWord(ev: Event, el: HTMLElement) {
      ev.stopPropagation();
      currentWord = el;
      var anchor = el.getAttribute('data-ru');
      var ru = (anchor && parallelOn) ? q(anchor) : null;
      var bar = q('wbar'); if (!bar) { return; }
      if (el.classList.contains('hl')) { clearHl(); bar.style.display = 'none'; return; }
      clearHl();
      el.classList.add('hl');
      if (ru) { ru.classList.add('hl'); }
      syncAddBtn();
      bar.style.visibility = 'hidden'; bar.style.display = 'flex';
      var cr = CARD_EL.getBoundingClientRect();
      var wr = el.getBoundingClientRect();
      var bw = bar.offsetWidth, bh = bar.offsetHeight;
      var wcx = wr.left - cr.left + wr.width / 2;
      var arrow = q('warrow');
      var top = wr.top - cr.top - bh - 9;
      if (top < 8) { top = 8; }
      var left = Math.max(8, Math.min(wcx - bw / 2, CARD_EL.clientWidth - bw - 8));
      bar.style.left = left + 'px'; bar.style.top = top + 'px';
      if (arrow) { arrow.style.left = (wcx - left) + 'px'; }
      bar.style.visibility = 'visible';
    }
    function closeBar(ev?: Event) { if (ev) { ev.stopPropagation(); } clearHl(); var wb = q('wbar'); if (wb) { wb.style.display = 'none'; } }
    function syncAddBtn() {
      var w = currentWord ? (currentWord.textContent || '').trim().toLowerCase() : '';
      var on = !!addedWords[w.replace(/[^a-z]/g, '')];
      var book = q('addBook'), spine = q('addSpine'), letter = q('addA');
      var pad = q('addPad'), pip = q('addPip'), pipIcon = q('addPipIcon');
      if (on) {
        if (book) { book.setAttribute('fill', '#34D399'); book.setAttribute('stroke', '#34D399'); }
        if (spine) { spine.setAttribute('stroke', '#ffffff'); } if (letter) { letter.setAttribute('fill', '#ffffff'); }
        if (pad) { pad.style.background = 'rgba(52,211,153,.14)'; } if (pip) { pip.style.background = '#34D399'; }
        if (pipIcon) { pipIcon.innerHTML = '<polyline points="20 6 9 17 4 12"></polyline>'; }
      } else {
        if (book) { book.setAttribute('fill', 'none'); book.setAttribute('stroke', '#3a3a4a'); }
        if (spine) { spine.setAttribute('stroke', '#3a3a4a'); } if (letter) { letter.setAttribute('fill', '#3a3a4a'); }
        if (pad) { pad.style.background = 'transparent'; } if (pip) { pip.style.background = '#aab0b4'; }
        if (pipIcon) { pipIcon.innerHTML = '<line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line>'; }
      }
    }
    function showToast() {
      var t = q('toast'); if (!t) { return; }
      t.style.opacity = '1'; t.style.transform = 'translateX(-50%) translateY(0)';
      setTimeout(function () { t.style.opacity = '0'; t.style.transform = 'translateX(-50%) translateY(12px)'; }, 1400);
    }
    function addWord(ev?: Event) {
      if (ev) { ev.stopPropagation(); }
      var w = currentWord ? (currentWord.textContent || '').trim().toLowerCase().replace(/[^a-z]/g, '') : '';
      if (!w) { return; }
      var nowOn = !addedWords[w];
      if (nowOn) { addedWords[w] = true; } else { delete addedWords[w]; }
      syncAddBtn();
      if (nowOn) { showToast(); }
    }
    document.addEventListener('click', function () {
      if (!autoOn) { closeBar(); }
      var lm = q('langMenu'); if (lm) { lm.style.display = 'none'; }
    });

    // ════════════ Save star ════════════
    var saved = false;
    function toggleSave(ev?: Event) {
      if (ev) { ev.stopPropagation(); }
      saved = !saved;
      var star = q('saveStar'); if (!star) { return; }
      star.style.color = saved ? '#f5b301' : '#c9ced2';
      star.style.transform = 'scale(1.25)';
      setTimeout(function () { star.style.transform = 'scale(1)'; }, 160);
    }

    // ════════════ Auto read-aloud ════════════
    var autoOn = false, autoTimer: ReturnType<typeof setTimeout> | null = null;
    var autoSteps: any[] = [], autoIdx = -1;
    var loopAudio = false;     // was window.__loopAudio (now per-instance)
    var muted = false;         // was global speechSynthesis.speak override (now per-instance)
    var PAUSE_OPTS = [3, 5, 10, 0], pauseSec = 5;
    var LETTER = /[A-Za-zА-Яа-яЁё؀-ۿ一-鿿]/;
    function pauseText() { return pauseSec === 0 ? 'Think pause · off' : 'Think pause · ' + pauseSec + 's'; }
    function cyclePause(ev?: Event) {
      if (ev) { ev.stopPropagation(); }
      var i = PAUSE_OPTS.indexOf(pauseSec);
      pauseSec = PAUSE_OPTS[(i + 1) % PAUSE_OPTS.length];
      var pl = q('pauseLabel'); if (pl) { pl.textContent = pauseText(); }
    }
    function setAutoBtn(on: boolean) {
      var b = q('autoBtn'); if (!b) { return; }
      if (on) { b.style.background = '#34D399'; b.style.borderColor = '#34D399';
        b.innerHTML = '<svg width="11" height="11" viewBox="0 0 24 24" fill="#fff"><rect x="6" y="5" width="4" height="14" rx="1"></rect><rect x="14" y="5" width="4" height="14" rx="1"></rect></svg>'; }
      else { b.style.background = '#fff'; b.style.borderColor = 'rgba(52,211,153,.55)';
        b.innerHTML = '<svg width="11" height="11" viewBox="0 0 24 24" fill="#047857"><polygon points="6 4 20 12 6 20 6 4"></polygon></svg>'; }
    }
    function speak(text: string, lang: string) {
      if (muted) { return; }              // hero demo mutes TTS but keeps the karaoke visual
      if (!window.speechSynthesis) { return; }
      try { window.speechSynthesis.cancel();
        var u = new SpeechSynthesisUtterance(text); u.lang = lang; u.rate = (lang === 'en-US') ? 0.85 : 0.95;
        window.speechSynthesis.speak(u);
      } catch (e) {}
    }
    function buildSteps() {
      var tl = LMETA[curLang].tts;
      var steps: any[] = [
        { el: q('qEN'), say: 'A legal claim against a property that must be paid off when the property is sold is called a', lang: 'en-US' }
      ];
      if (parallelOn) { steps.push({ el: q('qTrans'), say: plainSegs(I18N[curLang].q), lang: tl }); }
      steps.push({ el: q('optsBox'), opt: true, say: 'Answer options', lang: 'en-US' });
      steps.push({ el: q('opt0'), opt: true, say: 'an easement', lang: 'en-US' });
      steps.push({ el: q('opt1'), opt: true, say: 'a lien', lang: 'en-US' });
      steps.push({ el: q('opt2'), opt: true, say: 'an encumbrance', lang: 'en-US' });
      steps.push({ el: q('opt3'), opt: true, say: 'a deed', lang: 'en-US' });
      steps.push({ pause: true });
      steps.push({ el: q('opt1'), opt: true, reveal: true, say: 'Correct answer. A lien.', lang: 'en-US' });
      steps.push({ el: q('exEN'), say: 'A lien is a legal claim that stays with the property until the debt is paid. It must be cleared at closing.', lang: 'en-US' });
      if (parallelOn) { steps.push({ el: q('exTrans'), say: plainSegs(I18N[curLang].ex), lang: tl }); }
      return steps;
    }
    function startAuto() {
      autoOn = true; setAutoBtn(true);
      var wb = q('wbar'); if (wb) { wb.style.display = 'none'; }
      if (!loopAudio) { var bb = q('bottomBar'); if (bb) { bb.style.display = 'none'; } }
      var pr = q('pauseRow'); if (pr) { pr.style.display = 'flex'; }
      var pl = q('pauseLabel'); if (pl) { pl.textContent = pauseText(); }
      autoSteps = buildSteps(); autoIdx = -1; autoStep();
    }
    function stopAuto() {
      autoOn = false; if (autoTimer) { clearTimeout(autoTimer); } clearHl();
      var pp = q('pausePill'); if (pp) { pp.classList.remove('read'); }
      if (window.speechSynthesis) { try { window.speechSynthesis.cancel(); } catch (e) {} }
      setAutoBtn(false);
      var pr = q('pauseRow'); if (pr) { pr.style.display = 'none'; }
      var bb = q('bottomBar'); if (bb) { bb.style.display = 'flex'; }
    }
    function autoStep() {
      if (!autoOn) { return; }
      clearHl(); var pp = q('pausePill'); if (pp) { pp.classList.remove('read'); }
      autoIdx++;
      if (autoIdx >= autoSteps.length) { stopAuto(); if (loopAudio) { setTimeout(function () { if (loopAudio) { startAuto(); } }, 1500); } return; }
      var s = autoSteps[autoIdx];
      if (s.pause) {
        if (pauseSec === 0) { autoStep(); return; }
        var pill = q('pausePill'); if (pill) { pill.classList.add('read'); }
        var remain = pauseSec, lbl = q('pauseLabel');
        if (lbl) { lbl.textContent = 'Think… ' + remain + 's'; }
        var tick = setInterval(function () {
          remain--;
          if (remain <= 0 || !autoOn) { clearInterval(tick); if (lbl) { lbl.textContent = pauseText(); } }
          else { if (lbl) { lbl.textContent = 'Think… ' + remain + 's'; } }
        }, 1000);
        autoTimer = setTimeout(autoStep, pauseSec * 1000); return;
      }
      if (s.reveal && !answered) { revealAnswer(null); }
      if (s.opt) { if (s.el) { s.el.classList.add('read-opt'); } speak(s.say, s.lang); autoTimer = setTimeout(autoStep, 480 + 42 * s.say.length); }
      else { runStep(s); }
    }
    function wordSpansOf(el: HTMLElement) {
      if (!el.getAttribute('data-rw')) {
        Array.prototype.slice.call(el.childNodes).forEach(function (n: ChildNode) {
          if (n.nodeType === 3 && LETTER.test(n.nodeValue || '')) {
            var frag = document.createDocumentFragment();
            (n.nodeValue || '').split(/(\s+)/).forEach(function (tok) {
              if (LETTER.test(tok)) { var s = document.createElement('span'); s.className = 'rw'; s.textContent = tok; frag.appendChild(s); }
              else { frag.appendChild(document.createTextNode(tok)); }
            });
            el.replaceChild(frag, n);
          }
        });
        el.setAttribute('data-rw', '1');
      }
      return Array.prototype.slice.call(el.querySelectorAll('span')).filter(function (e: HTMLElement) {
        return !e.querySelector('span') && LETTER.test(e.textContent || '');
      });
    }
    function runStep(s: any) {
      var spans = wordSpansOf(s.el);
      speak(s.say, s.lang);
      var total = 480 + 42 * s.say.length;
      var per = Math.max(150, total / Math.max(1, spans.length));
      var i = -1;
      function adv() {
        if (!autoOn) { return; }
        if (i >= 0 && spans[i]) { spans[i].classList.remove('rw-on'); }
        i++;
        if (i >= spans.length) { autoTimer = setTimeout(autoStep, 240); return; }
        spans[i].classList.add('rw-on');
        autoTimer = setTimeout(adv, per);
      }
      adv();
    }
    function toggleAuto(ev?: Event) { if (ev) { ev.stopPropagation(); } if (autoOn) { stopAuto(); } else { startAuto(); } }

    // ════════════ Make every English word tappable ════════════
    function enableAllWords(name: string) {
      var p = q(name);
      if (!p) { return; }
      Array.prototype.slice.call(p.childNodes).forEach(function (node: ChildNode) {
        if (node.nodeType !== 3) { return; }
        var frag = document.createDocumentFragment();
        (node.nodeValue || '').split(/(\s+)/).forEach(function (tok) {
          var core = /[A-Za-z]/.test(tok) ? tok.match(/^([^A-Za-z]*)([A-Za-z][A-Za-z'’-]*)([^A-Za-z]*)$/) : null;
          if (core) {
            if (core[1]) { frag.appendChild(document.createTextNode(core[1])); }
            var s = document.createElement('span'); s.className = 'tw'; s.textContent = core[2]; s.onclick = function (e) { tapWord(e, s); };
            frag.appendChild(s);
            if (core[3]) { frag.appendChild(document.createTextNode(core[3])); }
          } else { frag.appendChild(document.createTextNode(tok)); }
        });
        p!.replaceChild(frag, node);
      });
    }

    // ════════════ Wire events (former inline on* handlers) ════════════
    var hdrBack = root.querySelector('.hdr-back') as HTMLElement | null;
    if (hdrBack) { hdrBack.addEventListener('click', function (e) { e.stopPropagation(); }); }
    var langChip = q('langChip'); if (langChip) { langChip.addEventListener('click', toggleLangMenu); }
    var langMenu = q('langMenu'); if (langMenu) { langMenu.addEventListener('click', function (e) { e.stopPropagation(); }); }
    var autoBtn = q('autoBtn'); if (autoBtn) { autoBtn.addEventListener('click', toggleAuto); }
    var saveBtn = q('saveBtn'); if (saveBtn) { saveBtn.addEventListener('click', toggleSave); }
    [0, 1, 2, 3].forEach(function (i) { var o = q('opt' + i); if (o) { o.addEventListener('click', function () { pickAnswer(i); }); } });
    var pauseBtn = q('pauseBtn'); if (pauseBtn) { pauseBtn.addEventListener('click', cyclePause); }
    // word tap handlers on the static .tw spans inside qEN/exEN
    root.querySelectorAll<HTMLElement>('[data-el="qEN"] .tw, [data-el="exEN"] .tw').forEach(function (el) {
      el.addEventListener('click', function (e) { tapWord(e, el); });
    });
    // floating word toolbar buttons
    var wbarPron = root.querySelector('[data-el="wbar"] .wbtn[title="Pronounce"]') as HTMLElement | null;
    if (wbarPron) { wbarPron.addEventListener('click', function (e) { e.stopPropagation(); }); }
    var addBtn = q('addBtn'); if (addBtn) { addBtn.addEventListener('click', addWord); }
    var cardBtn = q('cardBtn'); if (cardBtn) { cardBtn.addEventListener('click', openWordCard); }
    var closeBarBtn = q('closeBarBtn'); if (closeBarBtn) { closeBarBtn.addEventListener('click', closeBar); }
    // bottom-bar nav (decorative; stop bubbling so the doc click doesn't fire)
    root.querySelectorAll<HTMLElement>('.nav-btn').forEach(function (b) { b.addEventListener('click', function (e) { e.stopPropagation(); }); });
    // word-card sheet
    var wcScrim = q('wcScrim'); if (wcScrim) { wcScrim.addEventListener('click', closeWordCard); }
    var wcPlay = q('wcPlay'); if (wcPlay) { wcPlay.addEventListener('click', function (e) { e.stopPropagation(); }); }
    var wcCloseBtn = q('wcCloseBtn'); if (wcCloseBtn) { wcCloseBtn.addEventListener('click', closeWordCard); }
    var wcAddBtn = q('wcAddBtn'); if (wcAddBtn) { wcAddBtn.addEventListener('click', cardAdd); }

    enableAllWords('qEN');
    enableAllWords('exEN');

    // init
    applyLang();

    // ════════════ Demo orchestration (was the second <script>) ════════════
    // Demo language comes from ?lang on the page URL (site default: Spanish).
    var lang = (new URLSearchParams(location.search).get('lang') || 'es').toLowerCase();
    // switch the screen to the page language
    try {
      if (lang === 'en') { pickLang('off'); var __el = q('langLabel'); if (__el) { __el.textContent = 'EN'; } }
      else if (lang !== 'off' && LMETA[lang] && lang !== curLang) { pickLang(lang); }
    } catch (e) {}

    var frame = root;

    var runToken = 0;   // bumped on every play/pause to cancel stale async loops

    var finger = document.createElement('div');
    finger.setAttribute('aria-hidden', 'true');
    finger.style.cssText = 'position:absolute; left:50%; top:55%; width:30px; height:30px; border-radius:50%; background:radial-gradient(circle at 50% 38%, rgba(52,211,153,.62), rgba(52,211,153,.22)); border:2px solid rgba(255,255,255,.92); box-shadow:0 3px 12px rgba(26,26,46,.35); transform:translate(-50%,-50%) scale(1); transition:left 1.05s cubic-bezier(.4,.1,.25,1), top 1.05s cubic-bezier(.4,.1,.25,1), transform .16s ease, opacity .3s ease; opacity:0; pointer-events:none; z-index:9999;';
    frame.appendChild(finger);

    function sleep(ms: number) { return new Promise<void>(function (r) { setTimeout(r, ms); }); }
    function centerOf(el: HTMLElement) {
      var fr = frame.getBoundingClientRect(), r = el.getBoundingClientRect();
      // для строк-вариантов палец встаёт на начало текста, а не на центр строки
      var txt = el.querySelector ? el.querySelector('.opt-en') : null;
      if (txt) {
        var tr = txt.getBoundingClientRect();
        return { x: tr.left - fr.left + 14, y: r.top - fr.top + r.height / 2 };
      }
      return { x: r.left - fr.left + r.width / 2, y: r.top - fr.top + r.height / 2 };
    }
    function scrollInto(el: HTMLElement | null) {
      var sa = q('scrollArea');
      if (!sa || !el) { return; }
      var top = el.getBoundingClientRect().top - sa.getBoundingClientRect().top + sa.scrollTop;
      sa.scrollTop = Math.max(0, top - sa.clientHeight / 2 + 18);
    }
    async function moveTo(el: HTMLElement) {
      var c = centerOf(el);
      finger.style.left = c.x + 'px'; finger.style.top = c.y + 'px';
      await sleep(1080);
    }
    async function press() {
      finger.style.transform = 'translate(-50%,-50%) scale(.72)';
      await sleep(150);
      finger.style.transform = 'translate(-50%,-50%) scale(1)';
    }
    async function tap(el: HTMLElement | null, dwell?: number) {
      if (!el) { await sleep(dwell || 600); return; }
      await moveTo(el);
      await press();
      try { el.click(); } catch (e) {}
      await sleep(dwell || 600);
    }

    // Подсветить элемент (строку перевода) без тапа: палец подъезжает слева,
    // строка мягко загорается зелёным. «Смотри сюда» - визуальная опора под текстовую подсказку.
    async function flash(el: HTMLElement | null, dwell?: number) {
      if (!el) { await sleep(dwell || 1200); return; }
      scrollInto(el);
      await sleep(180);
      var fr = frame.getBoundingClientRect(), r = el.getBoundingClientRect();
      finger.style.left = (r.left - fr.left + 10) + 'px';   // слева от строки, не накрывая текст
      finger.style.top = (r.top - fr.top + r.height / 2) + 'px';
      await sleep(1080);                                     // дать пальцу доехать (видно движение)
      finger.style.transform = 'translate(-50%,-50%) scale(1.14)';
      var pbg = el.style.background, psh = el.style.boxShadow, pbr = el.style.borderRadius, ptr = el.style.transition;
      el.style.transition = 'background .3s ease, box-shadow .3s ease';
      el.style.borderRadius = '7px';
      el.style.background = 'rgba(52,211,153,.16)';
      el.style.boxShadow = '0 0 0 5px rgba(52,211,153,.16)';   // halo через box-shadow - без сдвига вёрстки
      await sleep(220);
      finger.style.transform = 'translate(-50%,-50%) scale(1)';
      await sleep(dwell || 1200);                            // держим подсветку - дать рассмотреть
      el.style.background = pbg; el.style.boxShadow = psh;
      setTimeout(function () { el.style.borderRadius = pbr; el.style.transition = ptr; }, 320);
    }

    function qs(sel: string) { return root.querySelector(sel) as HTMLElement | null; }
    function badge(id: string) { try { root.dispatchEvent(new CustomEvent('l7:badge', { bubbles: true, detail: { id: id } })); } catch (e) {} }

    async function run(token: number) {
      await sleep(1700); if (token !== runToken) { return; }   // дать экрану прорисоваться и «осмотреться»
      finger.style.opacity = '1';
      await sleep(450); if (token !== runToken) { return; }

      // РИТМ: подсказка показывается ДО действия, которое она описывает, с паузой
      // «прочитать». Потом палец делает действие (его видно), затем пауза «увидеть
      // результат». Текст плашки всегда совпадает с тем, что сейчас на экране.

      // 1. ПЕРЕВОД. Двуязычный вопрос уже на экране → подсказка про перевод; палец
      //    подъезжает к строке перевода, и она мягко подсвечивается (опора для взгляда).
      badge('translate');
      await sleep(1600); if (token !== runToken) { return; }   // дать прочитать подсказку
      await flash(q('qRU'), 1700); if (token !== runToken) { return; }   // подсветить строку перевода под вопросом
      await sleep(350); if (token !== runToken) { return; }

      // 2. СЛОВАРЬ. Сначала подсказка, потом тап по незнакомому слову и добавление.
      badge('dict');
      await sleep(1700); if (token !== runToken) { return; }   // прочитать подсказку ДО действия
      await tap(qs('[data-el="qEN"] .tw[data-ru="q-claim"]'), 1500); if (token !== runToken) { return; }   // тап по слову → тулбар
      await tap(q('addBtn'), 900); if (token !== runToken) { return; }   // добавить в словарь → тост
      await sleep(1500); if (token !== runToken) { return; }   // дочитать тост
      try { closeBar(ev0()); } catch (e) {}

      // 3. ОТВЕТ + РАЗБОР. Выбираем вариант → раскрывается разбор (текст + перевод).
      //    Подсказку про перевод разбора даём, когда он уже на экране, и подсвечиваем его.
      await sleep(700); if (token !== runToken) { return; }
      await tap(q('opt3'), 900); if (token !== runToken) { return; }   // выбрать вариант → разбор
      await sleep(1700); if (token !== runToken) { return; }   // увидеть, что разбор раскрылся
      badge('explain');
      await sleep(1000); if (token !== runToken) { return; }   // прочитать подсказку
      await flash(q('exRU'), 1800); if (token !== runToken) { return; }   // подсветить перевод разбора

      // 4. КАРТОЧКА СЛОВА. Подсказка, потом тап по термину и открытие карточки.
      badge('card');
      await sleep(1800); if (token !== runToken) { return; }   // прочитать подсказку ДО действия
      var lien = qs('[data-el="exEN"] .tw[data-ru="ru-lien"]');
      scrollInto(lien);
      await sleep(650); if (token !== runToken) { return; }
      await tap(lien, 1400); if (token !== runToken) { return; }   // тап по «lien» → тулбар
      await tap(qs('[data-el="wbar"] button[title="Word card"]'), 1000); if (token !== runToken) { return; }   // открыть карточку
      await sleep(2600); if (token !== runToken) { return; }   // перевод виден сразу - дать прочитать

      await tap(qs('[data-el="wcSheet"] button[title="Close"]'), 1200); if (token !== runToken) { return; }

      // 5. ОЗВУЧКА. Подсказка, потом проигрывание караоке (в hero TTS замьючен).
      badge('audio');
      await sleep(1800); if (token !== runToken) { return; }   // прочитать подсказку ДО действия
      var sa = q('scrollArea');
      if (sa) { sa.scrollTop = 0; }
      await sleep(600); if (token !== runToken) { return; }
      await tap(q('autoBtn'), 1000); if (token !== runToken) { return; }   // play → караоке по словам
      await sleep(4400); if (token !== runToken) { return; }

      // назад на каталог → демо зацикливается
      await tap(root.querySelector('.hdr-back') as HTMLElement | null, 850); if (token !== runToken) { return; }

      finger.style.opacity = '0';
      await sleep(450); if (token !== runToken) { return; }
      try { root.dispatchEvent(new CustomEvent('l7:nav', { bubbles: true, detail: { to: 'home', lang: lang } })); } catch (e) {}
    }

    // Режимы для встраивания в библиотеку:
    //   static - «Адаптивные тесты»: некликабельно, авто-демо по циклу (вариант → lien → словарь → звезда);
    //   audio  - «Аудио»: некликабельно, авто-старт озвучки-караоке (зациклено, TTS замьючен);
    //   (без mode) - hero-демо run() с CustomEvent.
    function ev0(): Event { return { stopPropagation: function () {} } as unknown as Event; }
    function resetQuiz() {
      answered = false;
      [0, 1, 2, 3].forEach(function (i) {
        var el = q('opt' + i); if (!el) { return; }
        el.style.border = '1.5px solid #e8eaec'; el.style.background = '#fff';
        var en = el.querySelector('.opt-en') as HTMLElement | null; if (en) { en.style.fontWeight = '500'; }
        var ru = el.querySelector('.opt-ru') as HTMLElement | null; if (ru) { ru.style.color = '#9aa1a0'; }
        var b = el.querySelector('.opt-badge') as HTMLElement | null; if (b) { b.style.display = 'none'; }
      });
      var ex = q('exBox'); if (ex) { ex.style.display = 'none'; }
      try { addedWords = {}; } catch (e) {}
      try { if (saved) { toggleSave(ev0()); } } catch (e) {}
      try { closeBar(ev0()); } catch (e) {}
      var sa = q('scrollArea'); if (sa) { sa.scrollTop = 0; }
    }
    async function runStatic(token: number) {
      frame.style.pointerEvents = 'none';            // глушим пользовательские клики
      while (true) {
        if (token !== runToken) { return; }
        resetQuiz();
        finger.style.opacity = '0';
        await sleep(850); if (token !== runToken) { return; }
        finger.style.opacity = '1';
        await sleep(260); if (token !== runToken) { return; }
        await tap(q('opt0'), 950); if (token !== runToken) { return; }   // 1. вариант «an easement»
        var lien = qs('[data-el="exEN"] .tw[data-ru="ru-lien"]');
        scrollInto(lien); await sleep(380); if (token !== runToken) { return; }
        await tap(lien, 850); if (token !== runToken) { return; }        // 2. слово lien в разборе → попап
        await tap(q('addBtn'), 1150); if (token !== runToken) { return; }   // 3. добавить в словарь
        try { closeBar(ev0()); } catch (e) {}                  // 4. тулбар закрываем без тапа по крестику
        await tap(q('saveBtn'), 1350); if (token !== runToken) { return; }   // 5. звезда (сохранить вопрос)
        finger.style.opacity = '0';
        await sleep(950); if (token !== runToken) { return; }
      }
    }
    // Сброс экрана к исходному виду перед каждым (пере)запуском демо: гасим
    // авто-озвучку, прячем палец и возвращаем его в нейтраль, закрываем карточку
    // слова и тулбар, снимаем ответ/звезду/добавленные слова, прокрутка вверх и
    // заново применяем язык страницы (?lang) - чтобы двуязычные строки снова были
    // видны, как при первой загрузке. Идемпотентно.
    function resetScreen() {
      if (autoOn) { stopAuto(); }
      loopAudio = false;
      try { closeWordCard(ev0()); } catch (e) {}
      try { closeBar(ev0()); } catch (e) {}
      resetQuiz();                              // ответ/опции/exBox/addedWords/звезда/скролл
      clearHl();
      finger.style.opacity = '0';
      finger.style.transform = 'translate(-50%,-50%) scale(1)';
      finger.style.left = '50%'; finger.style.top = '55%';
      // вернуть язык страницы (перевод снова включён, как было на init)
      try {
        if (lang === 'en') { pickLang('off'); var __el = q('langLabel'); if (__el) { __el.textContent = 'EN'; } }
        else if (lang !== 'off' && LMETA[lang]) { pickLang(lang); }
        else { applyLang(); }
      } catch (e) {}
    }

    var __mode = root.dataset.mode || '';
    if (__mode === 'static' || __mode === 'audio') {
      frame.style.pointerEvents = 'none';       // некликабельно
      muted = true;                             // library demos: no TTS audio
    } else {
      // hero demo: keep the karaoke VISUAL but mute its TTS
      muted = true;
    }

    // Управление через l7:play / l7:pause от hero-оркестратора (экраны больше не
    // перезагружаются). НИ ОДИН режим не стартует demo сам на init - только по play.
    // Токен-счётчик runToken отменяет in-flight async при каждом play/pause.
    function startDemo() {
      runToken++;
      resetScreen();
      var token = runToken;
      if (__mode === 'static') { runStatic(token); }
      else if (__mode === 'audio') {
        loopAudio = true;                       // зацикленная озвучка-караоке
        var b = q('autoBtn'); if (b) { b.click(); }
      } else {
        run(token);                             // hero finger-demo с начала
      }
    }
    function stopDemo() {
      runToken++;                               // отменяет все in-flight await-циклы
      loopAudio = false;
      if (autoOn) { stopAuto(); }               // оборвать караоке-озвучку, если шла
      finger.style.opacity = '0';
    }

    root.addEventListener('l7:play', startDemo);
    root.addEventListener('l7:pause', stopDemo);
  }

  document.querySelectorAll<HTMLElement>('[data-screen="quiz"]').forEach(initQuiz);
</script>
