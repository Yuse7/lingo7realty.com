---
// Inline demo screen: multiple-choice quiz question with parallel translation,
// answer reveal + explanation, tap-to-translate words, a word-card bottom sheet
// and a read-aloud (karaoke) auto mode. Was public/screens/Quiz Review Screen.html
// (an iframe). Inlined into the light DOM so Yandex Webvisor can record it.
//
// This screen appears up to THREE times on one page, so isolation is per-instance:
//  - root <div data-screen="quiz" data-mode={mode}> ; language read at runtime from ?lang
//  - all former id="x" → data-el="x"; JS reaches them via root.querySelector only
//    (NO getElementById survives — three instances would collide). Dynamically
//    rendered translation anchors (q-claim, ru-lien, …) are also data-el, scoped to root.
//  - styles in one <style is:global> block, every selector prefixed with
//    [data-screen="quiz"] (isolates from other screens AND covers elements created
//    in JS, which Astro's scoped CSS would miss); @keyframes prefixed quiz-…
//  - script (NOT is:inline) runs once; initQuiz(root) holds ALL state/functions in a
//    closure and is mapped over every [data-screen="quiz"] instance — each gets its own.
//  - mode comes from root.dataset.mode (was ?mode=static|audio):
//      static — non-clickable, looped auto-demo (pick → lien → dict → star);
//      audio  — non-clickable, auto karaoke read-aloud, looped, TTS muted;
//      (empty) — hero finger-demo run() + l7:* CustomEvents.
//  - protocol (was postMessage): listens root 'l7:play'/'l7:pause'; emits bubbling
//    CustomEvents 'l7:badge'{id} and 'l7:nav'{to:'home'} instead of window.parent.postMessage.
//  - NO mode autostarts on init: every mode (hero/static/audio) is driven by the hero
//    orchestrator via l7:play (reset to first-load look + (re)start from scratch) and
//    l7:pause (stop). A runToken cancels in-flight async after every await, so a repeat
//    l7:play restarts cleanly and l7:pause halts all loops (finger hidden, karaoke stopped).
const { mode = '' } = Astro.props;
---
<div class="screen" data-screen="quiz" data-mode={mode} style="width:320px; height:600px; overflow:hidden; border-radius:24px; background:#fff; position:relative; color:#1a1a2e; font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; box-shadow:0 12px 40px rgba(0,0,0,.12); display:flex; flex-direction:column;">

  <!-- Header -->
  <div data-el="appHeader" style="display:flex; align-items:center; gap:9px; padding:14px 16px 13px; flex-shrink:0; border-bottom:1px solid #eef0f0;">
    <button class="hdr-back" title="Back to topics">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3a3a4a" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
    </button>
    <span style="line-height:1.2; flex:1; min-width:0;"><span style="display:block; font-size:14px; font-weight:700; color:#1a1a2e;">Contracts</span></span>
    <div style="display:flex; align-items:center; gap:7px; flex-shrink:0; justify-content:flex-end;">
      <!-- Language selector -->
      <div style="position:relative; flex-shrink:0;">
        <button data-el="langChip" title="Translation language" style="display:flex; align-items:center; gap:4px; border:1.5px solid #34D399; background:#34D399; color:#fff; font-family:inherit; font-size:11px; font-weight:700; padding:0 8px; height:28px; border-radius:999px; cursor:pointer; white-space:nowrap;">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><line x1="3" y1="12" x2="21" y2="12"></line><path d="M12 3a14 14 0 0 1 0 18a14 14 0 0 1 0-18z"></path></svg>
          <span data-el="langLabel">RU</span><span style="font-size:8px;">▾</span>
        </button>
        <div data-el="langMenu" style="display:none; position:absolute; top:calc(100% + 6px); right:0; background:#fff; border:1px solid #eef0f0; border-radius:13px; box-shadow:0 8px 26px rgba(26,26,46,.18); padding:5px; min-width:170px; max-height:420px; overflow-y:auto; z-index:60;"></div>
      </div>
      <button data-el="autoBtn" title="Read aloud" style="display:flex; align-items:center; justify-content:center; border:1.5px solid rgba(52,211,153,.55); background:#fff; color:#047857; font-family:inherit; width:28px; height:28px; border-radius:50%; cursor:pointer; padding:0; flex-shrink:0;">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="#047857"><polygon points="6 4 20 12 6 20 6 4"></polygon></svg>
      </button>
      <span style="width:1px; height:18px; background:#e3e7e9; flex-shrink:0;"></span>
      <button data-el="saveBtn" title="Save question" style="display:flex; align-items:center; justify-content:center; border:none; background:none; cursor:pointer; width:28px; height:28px; padding:0; flex-shrink:0;">
        <span data-el="saveStar" style="font-size:19px; line-height:1; color:#c9ced2; transition:transform .16s, color .15s;">★</span>
      </button>
    </div>
  </div>

  <!-- Scrollable content -->
  <div data-el="scrollArea" style="flex:1; min-height:0; overflow-y:auto;">
  <!-- Question -->
  <div style="padding:13px 18px 4px;">
    <p data-el="qEN" style="margin:0; font-size:14px; font-weight:700; line-height:1.32;">A <span class="tw" data-ru="q-legal">legal</span> <span class="tw" data-ru="q-claim">claim</span> against a <span class="tw" data-ru="q-prop">property</span> that must be <span class="tw" data-ru="q-paid">paid off</span> when the <span class="tw" data-ru="">property</span> is <span class="tw" data-ru="q-sold">sold</span> is <span class="tw" data-ru="q-called">called</span> a…</p>
    <p data-el="qRU" class="ru-line" style="margin:5px 0 0; font-size:11.5px; color:#6b7280; line-height:1.45;"><span data-el="lngBadge" style="display:inline-block; vertical-align:1px; font-size:8.5px; font-weight:700; letter-spacing:.04em; color:#059669; background:rgba(52,211,153,.14); border-radius:4px; padding:1px 5px; margin-right:5px;">RU</span><span data-el="qTrans"></span></p>
  </div>

  <!-- Options -->
  <div data-el="optsBox" style="padding:6px 18px 0; display:flex; flex-direction:column; gap:5px;">
    <div data-el="opt0" class="opt" style="display:flex; align-items:center; justify-content:space-between; gap:10px; padding:7px 14px; border-radius:13px; border:1.5px solid #e8eaec; background:#fff; cursor:pointer;">
      <span style="min-width:0;"><span class="opt-en" style="display:block; font-size:13.5px; font-weight:500; color:#1a1a2e;">an easement</span><span class="ru-line opt-ru" style="display:block; font-size:10.5px; color:#9aa1a0; margin-top:1px;"></span></span>
      <span class="opt-badge" style="display:none; width:19px; height:19px; border-radius:50%; color:#fff; font-size:11px; align-items:center; justify-content:center; flex-shrink:0;"></span>
    </div>
    <div data-el="opt1" class="opt" style="display:flex; align-items:center; justify-content:space-between; gap:10px; padding:7px 14px; border-radius:13px; border:1.5px solid #e8eaec; background:#fff; cursor:pointer;">
      <span style="min-width:0;"><span class="opt-en" style="display:block; font-size:13.5px; font-weight:500; color:#1a1a2e;">a lien</span><span class="ru-line opt-ru" style="display:block; font-size:10.5px; color:#9aa1a0; margin-top:1px;"></span></span>
      <span class="opt-badge" style="display:none; width:19px; height:19px; border-radius:50%; color:#fff; font-size:11px; align-items:center; justify-content:center; flex-shrink:0;"></span>
    </div>
    <div data-el="opt2" class="opt" style="display:flex; align-items:center; justify-content:space-between; gap:10px; padding:7px 14px; border-radius:13px; border:1.5px solid #e8eaec; background:#fff; cursor:pointer;">
      <span style="min-width:0;"><span class="opt-en" style="display:block; font-size:13.5px; font-weight:500; color:#1a1a2e;">an encumbrance</span><span class="ru-line opt-ru" style="display:block; font-size:10.5px; color:#9aa1a0; margin-top:1px;"></span></span>
      <span class="opt-badge" style="display:none; width:19px; height:19px; border-radius:50%; color:#fff; font-size:11px; align-items:center; justify-content:center; flex-shrink:0;"></span>
    </div>
    <div data-el="opt3" class="opt" style="display:flex; align-items:center; justify-content:space-between; gap:10px; padding:7px 14px; border-radius:13px; border:1.5px solid #e8eaec; background:#fff; cursor:pointer;">
      <span style="min-width:0;"><span class="opt-en" style="display:block; font-size:13.5px; font-weight:500; color:#1a1a2e;">a deed</span><span class="ru-line opt-ru" style="display:block; font-size:10.5px; color:#9aa1a0; margin-top:1px;"></span></span>
      <span class="opt-badge" style="display:none; width:19px; height:19px; border-radius:50%; color:#fff; font-size:11px; align-items:center; justify-content:center; flex-shrink:0;"></span>
    </div>
  </div>

  <!-- Auto-mode pause label -->
  <div data-el="pauseRow" style="display:none; margin:8px 18px 0; align-items:center; justify-content:center;">
    <div data-el="pausePill" style="display:inline-flex; align-items:center; gap:8px; background:#f5f7f9; border:1px dashed #cdd6d3; border-radius:999px; padding:5px 6px 5px 13px;">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="#9aa1a0"><rect x="6" y="5" width="4" height="14" rx="1"></rect><rect x="14" y="5" width="4" height="14" rx="1"></rect></svg>
      <span data-el="pauseLabel" style="font-size:11px; font-weight:600; color:#6b7280; white-space:nowrap;">Think pause · 5s</span>
      <button data-el="pauseBtn" title="Change pause" style="display:flex; align-items:center; justify-content:center; width:20px; height:20px; border:none; background:#fff; border-radius:50%; cursor:pointer; box-shadow:0 1px 3px rgba(0,0,0,.1);">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z"></path></svg>
      </button>
    </div>
  </div>

  <!-- Explanation -->
  <div data-el="exBox" style="display:none; margin:11px 18px 0; padding:10px 14px; background:#f5f7f9; border-radius:12px;">
    <p data-el="exEN" style="margin:0; font-size:12px; line-height:1.4; color:#1a1a2e;">
      A <span class="tw" data-ru="ru-lien">lien</span> is a <span class="tw" data-ru="ru-legal">legal</span> <span class="tw" data-ru="ru-claim">claim</span> that <span class="tw" data-ru="ru-stays">stays</span> with the <span class="tw" data-ru="ru-prop">property</span> <span class="tw" data-ru="ru-until">until</span> the <span class="tw" data-ru="ru-debt">debt</span> is <span class="tw" data-ru="ru-paid">paid</span> - it must be <span class="tw" data-ru="ru-cleared">cleared</span> at <span class="tw" data-ru="ru-close">closing</span>.
    </p>
    <p data-el="exRU" class="ru-line" style="margin:4px 0 0; font-size:11px; color:#6b7280; line-height:1.4;"><span data-el="exTrans"></span></p>
  </div>
  </div><!-- /scrollArea -->

  <!-- Bottom bar -->
  <div data-el="bottomBar" style="flex-shrink:0; display:flex; align-items:center; justify-content:space-between; padding:11px 18px 15px; border-top:1px solid #f0f2f3; background:#fff;">
    <button class="nav-btn nav-back" title="Previous">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
    </button>
    <span style="font-size:14px; font-weight:700; color:#6b7280; font-variant-numeric:tabular-nums; letter-spacing:.02em;">4 <span style="color:#c0c5c9; font-weight:600;">/ 20</span></span>
    <button class="nav-btn nav-next" title="Next">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
    </button>
  </div>

  <!-- Floating word toolbar -->
  <div data-el="wbar" style="display:none; position:absolute; z-index:30; background:#fff; border-radius:12px; box-shadow:0 8px 24px rgba(26,26,46,.2); border:1px solid #eef0f0; padding:5px 6px; align-items:center; gap:3px;">
    <button class="wbtn" title="Pronounce">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3a3a4a" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" fill="#3a3a4a" stroke="none"></polygon><path d="M15.5 8.5a5 5 0 0 1 0 7"></path><path d="M19 5a10 10 0 0 1 0 14"></path></svg>
    </button>
    <span class="wsep"></span>
    <button data-el="addBtn" class="wbtn" title="Add to Dictionary" style="position:relative;">
      <span data-el="addPad" style="display:inline-flex; align-items:center; justify-content:center; padding:5px 7px; border-radius:8px; transition:background .18s;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path data-el="addBook" d="M5 5.5A1.5 1.5 0 0 1 6.5 4H18a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1H6.5A1.5 1.5 0 0 0 5 20.5z" stroke="#3a3a4a" stroke-width="1.8" stroke-linejoin="round"></path><path data-el="addSpine" d="M5 20.5A1.5 1.5 0 0 1 6.5 19H19" stroke="#3a3a4a" stroke-width="1.8" stroke-linejoin="round"></path><text data-el="addA" x="11.7" y="14.6" font-size="9" font-weight="800" text-anchor="middle" fill="#3a3a4a" font-family="Inter,sans-serif">A</text></svg>
      </span>
      <span data-el="addPip" style="position:absolute; top:1px; right:1px; width:13px; height:13px; border-radius:50%; display:flex; align-items:center; justify-content:center; background:#aab0b4; box-shadow:0 0 0 1.5px #fff;">
        <svg data-el="addPipIcon" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
      </span>
    </button>
    <span class="wsep"></span>
    <button class="wbtn" data-el="cardBtn" title="Word card">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3a3a4a" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2.5"></rect><line x1="7" y1="9.5" x2="17" y2="9.5"></line><line x1="7" y1="13.5" x2="13" y2="13.5"></line></svg>
    </button>
    <span class="wsep"></span>
    <button class="wbtn" data-el="closeBarBtn" title="Close">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#aab0b4" stroke-width="2.2" stroke-linecap="round"><line x1="6" y1="6" x2="18" y2="18"></line><line x1="18" y1="6" x2="6" y2="18"></line></svg>
    </button>
    <span data-el="warrow" style="position:absolute; top:100%; left:50%; transform:translateX(-50%); width:0; height:0; border-left:6px solid transparent; border-right:6px solid transparent; border-top:6px solid #fff; filter:drop-shadow(0 2px 1px rgba(26,26,46,.08));"></span>
  </div>

  <!-- Toast -->
  <div data-el="toast" style="position:absolute; left:50%; bottom:64px; transform:translateX(-50%) translateY(12px); opacity:0; transition:all .28s; display:flex; align-items:center; gap:7px; padding:9px 15px; background:#1a1a2e; color:#fff; font-size:12px; font-weight:600; border-radius:22px; pointer-events:none; z-index:40; white-space:nowrap;">
    <span style="color:#34D399;">✓</span> Saved
  </div>

  <!-- Word card sheet -->
  <div data-el="wcScrim" style="display:none; position:absolute; inset:0; background:rgba(26,26,46,.28); z-index:50;"></div>
  <div data-el="wcSheet" style="position:absolute; left:0; right:0; top:600px; z-index:51; transition:top .32s cubic-bezier(.34,1.2,.5,1); background:#f3f5f7; border-radius:22px 22px 24px 24px; box-shadow:0 -8px 32px rgba(26,26,46,.18); padding:0 0 16px;">
    <div style="background:#fff; border-radius:22px; padding:16px 18px 16px; box-shadow:0 2px 10px rgba(26,26,46,.05);">
      <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:12px;">
        <div style="min-width:0;">
          <div data-el="wcWord" style="font-size:27px; font-weight:800; color:#1a1a2e; line-height:1.05;">lien</div>
          <div data-el="wcIpa" style="font-size:14px; color:#9aa1a0; margin-top:5px;">[liːn]</div>
        </div>
        <div style="display:flex; align-items:center; gap:8px; flex-shrink:0;">
          <button data-el="wcPlay" title="Pronounce" style="border:none; background:#f4f6f7; border-radius:50%; width:38px; height:38px; cursor:pointer; display:flex; align-items:center; justify-content:center;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1a1a2e" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" fill="#1a1a2e" stroke="none"></polygon><path d="M15.5 8.5a5 5 0 0 1 0 7"></path><path d="M19 5a10 10 0 0 1 0 14"></path></svg>
          </button>
          <button data-el="wcCloseBtn" title="Close" style="border:none; background:#f4f6f7; border-radius:50%; width:38px; height:38px; cursor:pointer; display:flex; align-items:center; justify-content:center;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2.3" stroke-linecap="round"><line x1="6" y1="6" x2="18" y2="18"></line><line x1="18" y1="6" x2="6" y2="18"></line></svg>
          </button>
        </div>
      </div>

      <!-- PRO term -->
      <div data-el="wcPro" style="display:none; margin-top:14px;">
        <span style="display:inline-flex; align-items:center; gap:6px; font-size:10.5px; font-weight:800; letter-spacing:.04em; text-transform:uppercase; color:#047857; background:rgba(52,211,153,.14); border-radius:6px; padding:4px 10px 4px 8px;">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#047857" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
          Real Estate Concept
        </span>
        <div data-el="wcTr" style="font-size:18px; font-weight:600; color:#1a1a2e; margin-top:10px;"></div>
        <p data-el="wcDefEN" style="font-size:13.5px; color:#3a3a4a; line-height:1.5; margin:9px 0 0;"></p>
        <p data-el="wcDefRU" style="font-size:12px; color:#6b7280; line-height:1.45; margin:7px 0 0;"></p>
      </div>

      <!-- COMMON word -->
      <div data-el="wcCommon" style="display:none; margin-top:12px;">
        <div data-el="wcMeanings" style="font-size:16px; color:#1a1a2e; line-height:1.7;"></div>
      </div>
    </div>

    <div style="padding:14px 18px 0;">
      <button data-el="wcAddBtn" style="width:100%; border:none; background:linear-gradient(135deg,#4ade80,#22c55e); color:#fff; font-family:inherit; font-size:15px; font-weight:700; padding:14px 8px; border-radius:14px; cursor:pointer; box-shadow:0 4px 16px rgba(52,211,153,.32); display:flex; align-items:center; justify-content:center; gap:8px;">Add &amp; learn</button>
    </div>
  </div>

</div>

<style is:global>
  [data-screen="quiz"] .tw { cursor: pointer; border-bottom: 1px dotted #c6cfcc; }
  [data-screen="quiz"] .hl { background: #d4f4e4; color: #047857; border-radius: 4px; padding: 0 1px; box-decoration-break: clone; -webkit-box-decoration-break: clone; border-bottom-color: transparent; }
  [data-screen="quiz"] .rw-on { background: #ff4d4d; color: #fff; border-radius: 4px; box-shadow: 0 0 0 1px rgba(255,77,77,.35); transition: background .08s; }
  [data-screen="quiz"] .read { background: #eafaf2 !important; border-color: #34D399 !important; }
  [data-screen="quiz"] .read-opt { box-shadow: 0 0 0 2px #34D399, 0 2px 12px rgba(52,211,153,.3) !important; }
  [data-screen="quiz"] .nav-btn { width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: transform .08s ease, background .15s ease; flex-shrink: 0; }
  [data-screen="quiz"] .nav-btn:active { transform: scale(.9); }
  [data-screen="quiz"] .nav-back { border: 1.5px solid #d6dbe0; background: #fff; }
  [data-screen="quiz"] .nav-back:hover { background: #f5f7f9; }
  [data-screen="quiz"] .nav-next { border: none; background: #34D399; box-shadow: 0 4px 14px rgba(52,211,153,.32); }
  [data-screen="quiz"] .nav-next:hover { background: #2bc48a; }
  [data-screen="quiz"] .hdr-back { width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; border: none; background: #f4f6f7; flex-shrink: 0; transition: background .15s, transform .08s; padding: 0; }
  [data-screen="quiz"] .hdr-back:hover { background: #e9edee; }
  [data-screen="quiz"] .hdr-back:active { transform: scale(.9); }
  [data-screen="quiz"] .wbtn { display: flex; flex-direction: row; align-items: center; gap: 3px; border: none; background: none; cursor: pointer; font-family: inherit; padding: 4px 7px; border-radius: 8px; }
  [data-screen="quiz"] .wbtn:hover { background: #f5f7f9; }
  [data-screen="quiz"] .wbtn span { font-size: 11.5px; color: #3a3a4a; font-weight: 600; white-space: nowrap; }
  [data-screen="quiz"] .wsep { width: 1px; height: 16px; background: #eef0f0; flex-shrink: 0; }
  [data-screen="quiz"] .langOpt { display: flex; align-items: center; justify-content: space-between; gap: 10px; width: 100%; border: none; background: none; cursor: pointer; font-family: inherit; font-size: 12.5px; font-weight: 600; color: #1a1a2e; padding: 0 10px; min-height: 36px; line-height: 1.15; border-radius: 9px; text-align: left; }
  [data-screen="quiz"] .langOpt:hover { background: #f3f5f7; }
  [data-screen="quiz"] [data-el="langMenu"]::-webkit-scrollbar { width: 0; }
</style>

<script>
