---
// 13. Final CTA - заголовок + кнопка, ведущая на страницу тарифов /plans/.
// Карточка тарифа раньше клонировалась отсюда (<template id="pricingTpl">) в
// модалку; теперь это отдельная страница src/pages/plans.astro, а кнопка -
// обычная ссылка на неё.
---
<section class="final-cta" id="stores">
  <div class="container final-cta__inner">
    <h2 class="final-cta__title">Pass faster with the right plan</h2>
    <p class="final-cta__text">Pick your study window, see Sales Associate pricing, and start today - with your language right next to every exam term.</p>
    <a href="/plans/" class="btn btn--primary btn--lg">See plans &amp; pricing</a>
    <div class="final-cta__perks">
      <span>One-time payment · no auto-renewal</span>
      <span>14-day money-back guarantee, for any reason</span>
    </div>
  </div>
</section>
