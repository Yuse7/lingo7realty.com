---
// 13. Final CTA — pricing card. main.ts clones `.final-cta .pricing` into the
// pricing modal, so the role/plan selection logic is delegated and works in both.
---
<section class="final-cta" id="stores">
  <div class="container final-cta__inner">
    <div class="pricing">
      <div class="card">
        <span class="eyebrow" data-i18n="finalcta.eyebrow"><span class="pin"></span>Florida Real Estate</span>
        <h2 class="title" data-i18n="finalcta.title">Pass faster with the <span class="accent">right plan.</span></h2>
        <div class="roles">
          <button class="role active" data-role="sa" data-i18n="finalcta.role-sa"><span class="dot"></span>Sales Associate</button>
          <button class="role soon" data-role="broker" data-i18n="finalcta.role-broker"><span class="dot"></span>Broker <span class="soon-tag">Soon</span></button>
        </div>
        <div class="roles-msg" data-i18n="finalcta.roles-msg">Broker prep is on the way — join the Sales Associate track for now.</div>
        <div class="sub-q" data-i18n="finalcta.sub-q">How much study time do you want?</div>
        <div class="plans">
          <div class="plan" data-plan="1 Week" data-price="49"><span class="radio"></span><span class="plan-name" data-i18n="finalcta.plan-1week-name">1 Week</span><span class="plan-price" data-i18n="finalcta.plan-1week-price">$49</span></div>
          <div class="plan active" data-plan="1 Month" data-price="69"><span class="radio"></span><span class="plan-name" data-i18n="finalcta.plan-1month-name">1 Month</span><span class="plan-price" data-i18n="finalcta.plan-1month-price">$69</span><span class="badge" data-i18n="finalcta.plan-1month-badge">Most popular</span></div>
          <div class="plan" data-plan="3 Months" data-price="89"><span class="radio"></span><span class="plan-name" data-i18n="finalcta.plan-3months-name">3 Months</span><span class="plan-price" data-i18n="finalcta.plan-3months-price">$89</span><span class="save-tag" data-i18n="finalcta.plan-3months-save">Best value</span></div>
        </div>
        <div class="plans-note" data-i18n="finalcta.plans-note">One-time payment · no auto-renewal</div>
        <button class="cta">Get 1 Month<svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg></button>
        <div class="guarantee"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><polyline points="9 12 11 14 15 10"></polyline></svg> <span data-i18n="finalcta.guarantee">7-day money-back guarantee</span></div>
      </div>
    </div>
  </div>
</section>
