---
// 6. Library — exam-prep tools, each panel embeds a demo screen (iframe).
// data-src is upgraded to src (with ?lang) by main.ts so the screen loads in
// the chosen language and play/pause is driven by an IntersectionObserver.
---
<section class="library" id="library">
  <div class="container">
    <h2 class="section__title" data-i18n="library.title">Exam-prep tools — with your language built into every one</h2>
    <p class="section__subtitle" data-i18n="library.subtitle">The L7 language layer lets you prep for the exam in&nbsp;your own language.</p>

    <div class="library__panels">
      <div class="library__panel" data-tab="textbook">
        <div class="library__panel-content">
          <h3 data-i18n="library.textbook-title">Interactive textbook — with parallel translation and&nbsp;audio</h3>
          <p data-i18n="library.textbook-text">Everything you need for the&nbsp;exam — every paragraph in English and your language, with audio. You master the subject and build your professional English at the same time.</p>
          <div class="library__badges">
            <span class="library__badge" data-i18n="library.textbook-badge-1">EN + translation in your language</span>
            <span class="library__badge" data-i18n="library.textbook-badge-2">Audio</span>
            <span class="library__badge" data-i18n="library.textbook-badge-3">Spaced repetition</span>
          </div>
        </div>
        <div class="library__phone">
          <div class="phone-cased">
            <img src="/pics/phone-clean.svg" alt="" class="phone__shell" />
            <div class="phone__frame phone__frame--hero">
              <iframe data-src="/screens/Textbook%20Reading%20Screen.html?demo=1" title="Демо: интерактивный учебник — параллельный перевод, озвучка, тап → словарь" style="width:100%; height:100%; border:none; display:block;" scrolling="no"></iframe>
            </div>
          </div>
        </div>
      </div>

      <div class="library__panel" data-tab="tests">
        <div class="library__panel-content">
          <h3 data-i18n="library.tests-title">Adaptive tests by&nbsp;topic — with explanations in your language</h3>
          <p data-i18n="library.tests-text">Questions across every topic plus full practice exams in&nbsp;the real Florida exam format. The question, answer choices, and explanation all come with parallel translation.</p>
          <div class="library__badges">
            <span class="library__badge" data-i18n="library.tests-badge-1">The shortest path to a passing score</span>
            <span class="library__badge" data-i18n="library.tests-badge-2">Practice exams</span>
            <span class="library__badge" data-i18n="library.tests-badge-3">Translated explanations</span>
          </div>
        </div>
        <div class="library__phone">
          <div class="phone-cased">
            <img src="/pics/phone-clean.svg" alt="" class="phone__shell" />
            <div class="phone__frame phone__frame--hero">
              <iframe data-src="/screens/Quiz%20Review%20Screen.html?mode=static" title="Демо: тест с вариантами ответа и переведённым разбором" style="width:100%; height:100%; border:none; display:block;" scrolling="no"></iframe>
            </div>
          </div>
        </div>
      </div>

      <div class="library__panel" data-tab="cards">
        <div class="library__panel-content">
          <h3 data-i18n="library.cards-title">Key-term flashcards — memorize them by&nbsp;exam day</h3>
          <p data-i18n="library.cards-text">The front of the card shows the term; the back shows the definition with translation and audio. You review them on a smart schedule until you can recognize them with confidence on the test.</p>
          <div class="library__badges">
            <span class="library__badge" data-i18n="library.cards-badge-1">Term ↔ definition</span>
            <span class="library__badge" data-i18n="library.cards-badge-2">Audio</span>
            <span class="library__badge" data-i18n="library.cards-badge-3">Spaced repetition</span>
          </div>
        </div>
        <div class="library__phone">
          <div class="phone-cased">
            <img src="/pics/phone-clean.svg" alt="" class="phone__shell" />
            <div class="phone__frame phone__frame--hero">
              <iframe data-src="/screens/Term%20Card%20Screen.html?demo=1" title="Демо: умная карточка термина — перевод, аудио, пример, оценка усвоения" style="width:100%; height:100%; border:none; display:block;" scrolling="no"></iframe>
            </div>
          </div>
        </div>
      </div>

      <div class="library__panel" data-tab="audio">
        <div class="library__panel-content">
          <h3 data-i18n="library.audio-title">Listen to tests in two languages — even when your hands&nbsp;are full</h3>
          <p data-i18n="library.audio-text">The question plays in English, then comes the translation in your language. Listen while driving, at the gym, or on a walk — and turn that time into exam prep. Need a moment to think? Hit pause and run the answer through your head.</p>
          <div class="library__badges">
            <span class="library__badge" data-i18n="library.audio-badge-1">Hands-free mode</span>
            <span class="library__badge" data-i18n="library.audio-badge-2">Two voices: EN + translation</span>
            <span class="library__badge" data-i18n="library.audio-badge-3">Prep on the go</span>
          </div>
        </div>
        <div class="library__phone">
          <div class="phone-cased">
            <img src="/pics/phone-clean.svg" alt="" class="phone__shell" />
            <div class="phone__frame phone__frame--hero">
              <iframe data-src="/screens/Quiz%20Review%20Screen.html?mode=audio" title="Демо: аудио-режим — озвучка вопроса и перевода (караоке)" style="width:100%; height:100%; border:none; display:block;" scrolling="no"></iframe>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>
