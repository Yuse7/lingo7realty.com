---
// 11. Reviews - testimonials with a photo per person (placeholder copy per project brief).
// photo: path under /pics/reviews/ when a real photo exists; otherwise an initials placeholder is rendered.
const reviews = [
  {
    name: 'Carmen R.',
    lang: 'Spanish',
    photo: '/pics/reviews/carmen.jpg',
    photoPos: '58% center',
    licensed: true,
    text: 'I sold real estate for years back home, so none of the ideas were new to me, the English was the wall. Once the language stopped fighting me, I was answering with what I already knew. The day I passed it felt like I got my career back.',
  },
  {
    name: 'Polina R.',
    lang: 'Русский',
    photo: '/pics/reviews/polina.jpg',
    licensed: true,
    text: 'I always knew I could learn the material, the problem was my English. The legal terms never stayed in my head, I would read one and forget it minutes later. Slowly they stopped scaring me, and by the exam those words finally felt like mine.',
  },
  {
    name: 'Giulia M.',
    lang: 'Italian',
    photo: '/pics/reviews/giulia.jpg',
    licensed: true,
    text: 'It was never the real estate that scared me. It was reading a long legal sentence in English and doubting almost every word in it. That fear used to follow me into every practice test. At some point it just went away, and I stopped translating in my head and simply understood.',
  },
  {
    name: 'João P.',
    lang: 'Portuguese',
    photo: '/pics/reviews/joao.jpg',
    licensed: true,
    text: 'I almost gave up. Three years in this country and my English still felt small. Some nights I was sure this license was not for someone like me. Then little by little it started to make sense. The day I passed I called my mother and I cried. I did it.',
  },
  {
    name: 'Jean B.',
    lang: 'Haitian Creole',
    photo: '/pics/reviews/jean.jpg',
    licensed: true,
    text: 'I work long days, so I studied in small pieces, on my breaks and on the bus home. I was tired and I doubted myself the whole way. Passing on the first try meant everything to me. Thank you for not making me choose between my language and my license.',
  },
  {
    name: 'Sofia V.',
    lang: 'Spanish',
    photo: '/pics/reviews/sofia.jpg',
    licensed: true,
    text: 'Hundreds of terms in a language that is not mine, I really thought this was not for me. But the exam was never the real problem, my English was. The day I passed I sat in my car and cried. Thank you for believing people like us can do this.',
  },
];

const initials = (name) => name.split(' ').map((p) => p[0]).join('').slice(0, 2).toUpperCase();
---
<section class="reviews" id="reviews">
  <div class="container">
    <h2 class="section__title" data-i18n="reviews.title">What people who passed are saying</h2>
    <p class="section__subtitle" data-i18n="reviews.subtitle">They started exactly where you are now.</p>
    <div class="reviews__grid">
      {reviews.map((r) => (
        <article class="reviews__card">
          <div class="reviews__photo">
            {r.photo
              ? <img src={r.photo} alt={`${r.name}, licensed real estate agent`} loading="lazy" style={r.photoPos ? `object-position:${r.photoPos}` : undefined} />
              : <span class="reviews__photo-ph" aria-hidden="true">{initials(r.name)}</span>}
            {r.licensed && (
              <span class="reviews__badge">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"></path></svg>
                Licensed
              </span>
            )}
          </div>
          <div class="reviews__body">
            <div class="reviews__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <p class="reviews__text">{r.text}</p>
            <div class="reviews__author">
              <strong>{r.name}</strong>
              <span class="reviews__source">{r.lang}</span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
